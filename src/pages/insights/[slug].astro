---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import { SITE } from '@/data/site';

export async function getStaticPaths() {
  const articles = await getCollection('insights', ({ data }) => !data.draft);
  return articles.map((article) => ({
    params: { slug: article.slug },
    props: { article },
  }));
}

type Props = { article: CollectionEntry<'insights'> };

const { article } = Astro.props;
const { Content } = await article.render();

const {
  title,
  description,
  pubDate,
  category,
  categorySlug,
  tags,
  image,
  imageAlt,
  author,
} = article.data;

const dateFormatted = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const dateIso = pubDate.toISOString().slice(0, 10);
const canonicalPath = `/insights/${article.slug}/`;
const categoryHref = `/insights/${categorySlug}/`;

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  datePublished: dateIso,
  author: {
    '@type': 'Person',
    name: author,
    url: SITE.url,
  },
  publisher: {
    '@type': 'Person',
    name: SITE.name,
    url: SITE.url,
  },
  mainEntityOfPage: new URL(canonicalPath, SITE.url).href,
};
---

<BaseLayout
  title={title}
  description={description}
  ogImage={image || SITE.ogImage}
  canonical={canonicalPath}
  structuredData={[articleSchema]}
>

  <!-- ── Article Header ──────────────────────────────────────────────────── -->
  <section class="article-header" aria-label="Article header">
    <div class="container-site">

      <!-- Back nav -->
      <nav class="article-breadcrumb" aria-label="Breadcrumb">
        <a href="/insights/" class="back-link">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <path d="M12 7H2M6 3L2 7l4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          All Insights
        </a>
        <span class="breadcrumb-sep" aria-hidden="true">/</span>
        <a href={categoryHref} class="breadcrumb-category">{category}</a>
      </nav>

      <!-- Title -->
      <h1 class="article-title">{title}</h1>

      <!-- Meta -->
      <div class="article-meta" aria-label="Article metadata">
        <span class="meta-category">{category}</span>
        <span class="meta-sep" aria-hidden="true">·</span>
        <time datetime={dateIso} class="meta-date">{dateFormatted}</time>
        <span class="meta-sep" aria-hidden="true">·</span>
        <span class="meta-author">{author}</span>
      </div>

      <!-- Tags -->
      {tags.length > 0 && (
        <ul class="article-tags" aria-label="Article tags">
          {tags.map((tag) => (
            <li class="tag-pill">{tag}</li>
          ))}
        </ul>
      )}

    </div>
  </section>

  <!-- ── Optional Hero Image ──────────────────────────────────────────────── -->
  {image && (
    <div class="article-image-wrapper">
      <div class="container-site">
        <img
          src={image}
          alt={imageAlt || ''}
          class="article-hero-image"
          loading="eager"
          decoding="async"
        />
      </div>
    </div>
  )}

  <!-- ── Article Body ─────────────────────────────────────────────────────── -->
  <section class="article-body-section" aria-label="Article content">
    <div class="container-site">
      <div class="article-body">
        <Content />
      </div>
    </div>
  </section>

  <!-- ── Article Footer ──────────────────────────────────────────────────── -->
  <section class="article-footer-section" aria-label="Article navigation">
    <div class="container-site">
      <div class="article-footer">
        <a href="/insights/" class="back-link-footer">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <path d="M12 7H2M6 3L2 7l4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          Back to Insights
        </a>
        <a href="/contact" class="btn-primary">
          Book an Advisory Call
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ── Header ─────────────────────────────────────────────────────────────── */
  .article-header {
    background: #070B14;
    padding-block: 80px 64px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .article-breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 2rem;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.84rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.45);
    text-decoration: none;
    transition: color 180ms ease;
  }

  .back-link:hover { color: rgba(255, 255, 255, 0.8); }

  .breadcrumb-sep { color: rgba(255, 255, 255, 0.2); font-size: 0.84rem; }

  .breadcrumb-category {
    font-size: 0.84rem;
    font-weight: 600;
    color: rgba(245, 124, 0, 0.75);
    text-decoration: none;
    transition: color 180ms ease;
  }

  .breadcrumb-category:hover { color: #F57C00; }

  .article-title {
    font-family: Manrope, system-ui, sans-serif;
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 800;
    color: #ffffff;
    line-height: 1.12;
    margin: 0 0 1.25rem;
    max-width: 820px;
  }

  .article-meta {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    flex-wrap: wrap;
    margin-bottom: 1rem;
  }

  .meta-category {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #F57C00;
  }

  .meta-sep { color: rgba(255, 255, 255, 0.2); }

  .meta-date,
  .meta-author {
    font-size: 0.84rem;
    color: rgba(255, 255, 255, 0.45);
  }

  .article-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .tag-pill {
    padding: 0.25rem 0.7rem;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 999px;
    font-size: 0.72rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.5);
    background: rgba(255, 255, 255, 0.04);
  }

  /* ── Hero Image ──────────────────────────────────────────────────────────── */
  .article-image-wrapper {
    background: #070B14;
    padding-block: 0 48px;
  }

  .article-hero-image {
    width: 100%;
    max-height: 480px;
    object-fit: cover;
    border-radius: 1rem;
    border: 1px solid rgba(255, 255, 255, 0.07);
  }

  /* ── Body ───────────────────────────────────────────────────────────────── */
  .article-body-section {
    background: #070B14;
    padding-block: 64px 80px;
  }

  .article-body {
    max-width: 68ch;
  }

  /* Prose-like styles for markdown output */
  .article-body :global(h2) {
    font-family: Manrope, system-ui, sans-serif;
    font-size: 1.5rem;
    font-weight: 700;
    color: #ffffff;
    line-height: 1.2;
    margin: 2.75rem 0 1rem;
  }

  .article-body :global(h3) {
    font-family: Manrope, system-ui, sans-serif;
    font-size: 1.15rem;
    font-weight: 700;
    color: rgba(255, 255, 255, 0.9);
    line-height: 1.25;
    margin: 2rem 0 0.75rem;
  }

  .article-body :global(p) {
    color: rgba(255, 255, 255, 0.72);
    font-size: 1rem;
    line-height: 1.8;
    margin: 0 0 1.4rem;
  }

  .article-body :global(ul),
  .article-body :global(ol) {
    color: rgba(255, 255, 255, 0.72);
    font-size: 1rem;
    line-height: 1.75;
    margin: 0 0 1.4rem;
    padding-left: 1.5rem;
  }

  .article-body :global(li) {
    margin-bottom: 0.4rem;
  }

  .article-body :global(blockquote) {
    border-left: 2px solid rgba(245, 124, 0, 0.5);
    padding-left: 1.25rem;
    margin: 1.75rem 0;
    color: rgba(255, 255, 255, 0.6);
    font-style: italic;
  }

  .article-body :global(strong) {
    color: rgba(255, 255, 255, 0.9);
    font-weight: 700;
  }

  .article-body :global(a) {
    color: rgba(245, 124, 0, 0.85);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color 160ms ease;
  }

  .article-body :global(a:hover) {
    color: #F57C00;
  }

  .article-body :global(code) {
    background: rgba(255, 255, 255, 0.08);
    border-radius: 4px;
    padding: 0.15em 0.4em;
    font-size: 0.88em;
    color: rgba(255, 255, 255, 0.85);
  }

  .article-body :global(pre) {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 0.75rem;
    padding: 1.25rem 1.5rem;
    overflow-x: auto;
    margin: 0 0 1.5rem;
  }

  .article-body :global(pre code) {
    background: none;
    padding: 0;
    border-radius: 0;
    font-size: 0.88rem;
  }

  .article-body :global(hr) {
    border: none;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    margin: 2.5rem 0;
  }

  /* ── Footer ─────────────────────────────────────────────────────────────── */
  .article-footer-section {
    background: #070B14;
    padding-block: 0 80px;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  .article-footer {
    padding-top: 48px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .back-link-footer {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.84rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.45);
    text-decoration: none;
    transition: color 180ms ease;
  }

  .back-link-footer:hover { color: rgba(255, 255, 255, 0.8); }
</style>
