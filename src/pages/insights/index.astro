---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { INSIGHT_PILLARS } from '@/data/insightPillars';

const articles = (await getCollection('insights', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const hasArticles = articles.length > 0;

/* Topic card icons — 28×28, stroke="currentColor", identical style to homepage advisory icons */
const TOPIC_ICONS: string[] = [
  // AI Strategy — hub-satellite neural network
  `<svg width="28" height="28" viewBox="0 0 28 28" fill="none" aria-hidden="true">
    <circle cx="14"   cy="3.5"  r="2.1" stroke="currentColor" stroke-width="1.4"/>
    <circle cx="23.1" cy="19.6" r="2.1" stroke="currentColor" stroke-width="1.4"/>
    <circle cx="4.9"  cy="19.6" r="2.1" stroke="currentColor" stroke-width="1.4"/>
    <circle cx="14"   cy="14"   r="2.6" stroke="currentColor" stroke-width="1.4"/>
    <line x1="14"   y1="5.6"  x2="14"   y2="11.4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
    <line x1="21.4" y1="18.1" x2="16.3" y2="15.4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
    <line x1="6.6"  y1="18.1" x2="11.7" y2="15.4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
  </svg>`,
  // Digital Transformation — stacked diamond layers
  `<svg width="28" height="28" viewBox="0 0 28 28" fill="none" aria-hidden="true">
    <path d="M14 3L26 9L14 15L2 9Z"   stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/>
    <path d="M2 14L14 20L26 14"       stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
    <path d="M2 19L14 25L26 19"       stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
  </svg>`,
  // Operational Excellence — ascending performance bars
  `<svg width="28" height="28" viewBox="0 0 28 28" fill="none" aria-hidden="true">
    <rect x="3"    y="19" width="5.5" height="6"  rx="1" stroke="currentColor" stroke-width="1.4"/>
    <rect x="11.3" y="13" width="5.5" height="12" rx="1" stroke="currentColor" stroke-width="1.4"/>
    <rect x="19.5" y="5"  width="5.5" height="20" rx="1" stroke="currentColor" stroke-width="1.4"/>
  </svg>`,
  // Strategy Execution — pipeline nodes (strategy → execution flow)
  `<svg width="28" height="28" viewBox="0 0 28 28" fill="none" aria-hidden="true">
    <circle cx="5"  cy="14" r="2.5" stroke="currentColor" stroke-width="1.4"/>
    <circle cx="14" cy="14" r="2.5" stroke="currentColor" stroke-width="1.4"/>
    <circle cx="23" cy="14" r="2.5" stroke="currentColor" stroke-width="1.4"/>
    <line x1="7.5"  y1="14" x2="11.5" y2="14" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
    <line x1="16.5" y1="14" x2="20.5" y2="14" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
    <path d="M5 9c3-1.5 6-1.5 9 0s6 1.5 9 0" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" fill="none" opacity="0.4"/>
  </svg>`,
];

/* Filter chips */
const FILTER_CHIPS = [
  { label: 'All', active: true },
  { label: 'AI Strategy', active: false },
  { label: 'Digital Transformation', active: false },
  { label: 'Operational Excellence', active: false },
  { label: 'Enterprise Agility', active: false },
  { label: 'Strategy Execution', active: false },
];

/* Placeholder articles — shown when content collection is empty.
   Replace this section with real collection data when articles are published. */
interface StaticArticle {
  category: string;
  title: string;
  excerpt: string;
  date: string;
  readTime: string;
}

const STATIC_ARTICLES: StaticArticle[] = [
  {
    category: 'GOVERNANCE',
    title: 'Establishing the Ethics & Policy Board',
    excerpt: 'How leaders formalize responsible AI governance before scaling AI adoption.',
    date: 'May 8, 2026',
    readTime: '5 min read',
  },
  {
    category: 'IMPACT',
    title: 'Measuring AI ROI Beyond Productivity Gains',
    excerpt: 'A practical view on connecting AI initiatives to operating model and business performance.',
    date: 'April 23, 2026',
    readTime: '6 min read',
  },
  {
    category: 'OPERATING MODELS',
    title: 'The Hybrid AI Center of Excellence',
    excerpt: 'How organizations balance centralized governance with distributed AI execution.',
    date: 'March 18, 2026',
    readTime: '7 min read',
  },
  {
    category: 'EXECUTION',
    title: 'From Pilot to Production: Scaling AI',
    excerpt: 'The real blockers organizations face when moving beyond isolated AI experiments.',
    date: 'March 6, 2026',
    readTime: '5 min read',
  },
  {
    category: 'STRATEGY',
    title: 'AI as a Competitive Moat in 2026',
    excerpt: 'Understanding where AI creates durable advantage and where it only accelerates parity.',
    date: 'Feb 17, 2026',
    readTime: '6 min read',
  },
  {
    category: 'LEADERSHIP',
    title: 'Leading Through Technological Disruption',
    excerpt: 'Critical leadership conversations senior teams need during AI-driven transformation.',
    date: 'Feb 12, 2026',
    readTime: '4 min read',
  },
];

const SEO_TITLE = 'Insights | AI Strategy & Transformation';
const SEO_DESCRIPTION = 'Insights on AI strategy, digital transformation, operating models and execution for leaders driving measurable business impact.';
---

<BaseLayout
  title={SEO_TITLE}
  description={SEO_DESCRIPTION}
  canonical="/insights/"
  structuredData={[{
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: 'Strategic Insights — Facundo Gangemi',
    description: SEO_DESCRIPTION,
    url: 'https://facundogangemi.com/insights/',
    author: {
      '@type': 'Person',
      name: 'Facundo Gangemi',
      url: 'https://facundogangemi.com',
    },
  }]}
>

  <!-- INSIGHTS_SECTION_01_HERO ─────────────────────────────────────────────── -->
  <section
    id="insights-hero"
    class="section-py"
    style="background: #05070D;"
    aria-labelledby="insights-h1"
  >
    <div class="container-site">
      <div class="insights-hero-layout">

        <!-- Left: editorial text -->
        <div class="insights-hero-text">
          <span class="eyebrow">Insights</span>
          <h1
            id="insights-h1"
            class="insights-h1 font-heading font-bold text-white reveal"
          >
            Strategic Perspectives on AI, Transformation and Execution
          </h1>
          <p class="insights-hero-lead reveal delay-100">
            Explore selected perspectives on AI strategy, digital transformation,
            operational excellence, enterprise agility and measurable business impact.
          </p>
          <p class="insights-hero-sub reveal delay-200">
            Selected insights designed to connect strategy, operating models, governance
            and execution discipline.
          </p>
          <div class="insights-hero-cta reveal delay-300">
            <a href="#latest-insights" class="btn-primary">
              Read Latest Insights
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </div>
          <p class="insights-hero-topics reveal delay-300" aria-label="Topics: AI Strategy, Operating Models, Governance, Execution">
            AI Strategy · Operating Models · Governance · Execution
          </p>
        </div>

        <!-- Right: editorial hero image -->
        <div class="insights-hero-visual reveal delay-200">
          <div class="insights-hero-image-wrap">
            <img
              src="/images/insights/insights-hero-editorial.webp"
              alt="Editorial visual representing AI strategy, transformation insights and executive decision-making"
              width="760"
              height="570"
              loading="eager"
              decoding="async"
              class="insights-hero-img"
            />
            <div class="insights-hero-fade-left" aria-hidden="true"></div>
            <div class="insights-hero-fade-bottom" aria-hidden="true"></div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- INSIGHTS_SECTION_03_FILTERS_AND_SEARCH ──────────────────────────────── -->
  <section
    id="insights-filters"
    class="section-py-sm bg-gray-950"
    aria-labelledby="filters-section-heading"
  >
    <div class="container-site">
      <span class="eyebrow">Explore Insights</span>
      <h2 id="filters-section-heading" class="sr-only">Filter and search insights by topic</h2>
      <p class="filters-sub reveal">Find perspectives by topic, discipline or strategic priority.</p>

      <!-- Search input -->
      <div class="search-row reveal">
        <div class="search-wrap">
          <svg class="search-icon-svg" width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
            <circle cx="7.5" cy="7.5" r="5.5" stroke="currentColor" stroke-width="1.5"/>
            <path d="M12 12l3.5 3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
          <label for="insights-search" class="sr-only">Search insights</label>
          <input
            id="insights-search"
            type="search"
            name="q"
            placeholder="Search insights..."
            class="search-input"
            autocomplete="off"
          />
        </div>
      </div>

      <!-- Filter chips
           To enable functional filtering: add a JS module that listens to
           button clicks, updates aria-pressed, and filters visible insight cards
           by matching data-category attributes. -->
      <div
        class="filter-chips reveal delay-100"
        role="group"
        aria-label="Filter insights by topic"
      >
        {FILTER_CHIPS.map((chip) => (
          <button
            type="button"
            class={`filter-chip${chip.active ? ' filter-chip--active' : ''}`}
            aria-pressed={chip.active ? 'true' : 'false'}
          >
            {chip.label}
          </button>
        ))}
      </div>

    </div>
  </section>

  <!-- INSIGHTS_SECTION_02_FEATURED_INSIGHT ─────────────────────────────────── -->
  <section
    id="featured-insight"
    class="section-py-sm"
    style="background: #05070D;"
    aria-labelledby="featured-insight-heading"
  >
    <div class="container-site">
      <span class="eyebrow">Featured Insight</span>
      <div class="featured-card reveal">

        <!-- Left: content -->
        <div class="featured-content">
          <div class="featured-category-badge">AI Strategy</div>
          <h2
            id="featured-insight-heading"
            class="featured-title font-heading font-bold text-white"
          >
            Why AI Strategy Fails Without an Operating Model
          </h2>
          <p class="featured-summary">
            Most AI initiatives do not fail because of technology alone. They fail when
            organizations scale experimentation without governance, decision routines,
            ownership and execution discipline.
          </p>
          <div class="featured-meta">
            <time class="featured-date">May 12, 2026</time>
            <span class="featured-sep" aria-hidden="true">·</span>
            <span class="featured-read-time">6 min read</span>
          </div>
          <a href="/insights/ai-strategy/" class="btn-primary featured-cta-btn">
            Read Insight
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>

        <!-- Right: abstract visual (decorative) -->
        <div class="featured-visual" aria-hidden="true">
          <div class="featured-visual-inner">
            <div class="fv-accent"></div>
            <div class="fv-label">Operating Model · AI Governance</div>
            <div class="fv-grid">
              <div class="fv-cell fv-cell-orange"></div>
              <div class="fv-cell"></div>
              <div class="fv-cell fv-cell-dim"></div>
              <div class="fv-cell fv-cell-orange fv-cell-short"></div>
            </div>
            <div class="fv-lines">
              <div class="fv-line fv-line-long"></div>
              <div class="fv-line fv-line-med"></div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- INSIGHTS_SECTION_04_EDITORIAL_TOPICS ─────────────────────────────────── -->
  <section
    id="editorial-topics"
    class="section-py bg-gray-950"
    aria-labelledby="topics-heading"
  >
    <div class="container-site">
      <div class="topics-layout">

        <!-- Left: editorial header -->
        <div class="topics-text-col reveal">
          <span class="eyebrow">Strategic Perspectives</span>
          <h2
            id="topics-heading"
            class="topics-heading font-heading font-bold text-white"
          >
            Explore selected themes on AI strategy, transformation and execution.
          </h2>
          <p class="topics-sub">
            Selected perspectives designed to connect strategy, operating models, operational
            excellence and measurable business impact.
          </p>
          <a href="/insights/" class="topics-view-all">
            View all insights
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>

        <!-- Right: 2×2 topic cards -->
        <div class="topics-card-grid">
          {INSIGHT_PILLARS.map((pillar, i) => (
            <a
              href={pillar.href}
              class={`topic-card reveal delay-${(i % 2) * 100}`}
              aria-label={`${pillar.title} insights`}
            >
              <div class="topic-card-icon" set:html={TOPIC_ICONS[i]} />
              <h3 class="topic-card-title">{pillar.title}</h3>
              <p class="topic-card-desc">{pillar.description}</p>
              <span class="topic-card-cta">
                {pillar.cta}
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                  <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
            </a>
          ))}
        </div>

      </div>
    </div>
  </section>

  <!-- INSIGHTS_SECTION_05_LATEST_INSIGHTS ─────────────────────────────────── -->
  <section
    id="latest-insights"
    class="section-py"
    style="background: #05070D;"
    aria-labelledby="latest-heading"
  >
    <div class="container-site">
      <span class="eyebrow">Latest Insights</span>
      <h2
        id="latest-heading"
        class="latest-heading font-heading font-semibold text-white reveal"
      >
        Latest Insights
      </h2>
      <p class="latest-sub reveal delay-100">
        Recent perspectives on AI strategy, operating models, governance and transformation execution.
      </p>

      <div class="latest-grid">
        {hasArticles ? (
          /* Real articles from content collection */
          articles.slice(0, 6).map((article) => {
            const date = article.data.pubDate.toLocaleDateString('en-US', {
              year: 'numeric', month: 'long', day: 'numeric',
            });
            return (
              <a
                href={`/insights/${article.slug}/`}
                class="insight-card reveal"
                aria-label={`Read: ${article.data.title}`}
              >
                <div class="insight-card-meta">
                  <span class="insight-category">{article.data.category.toUpperCase()}</span>
                  <time
                    datetime={article.data.pubDate.toISOString().slice(0, 10)}
                    class="insight-date"
                  >
                    {date}
                  </time>
                </div>
                <h3 class="insight-title">{article.data.title}</h3>
                <p class="insight-excerpt">{article.data.description}</p>
                <span class="insight-cta">
                  Read insight
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                    <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </span>
              </a>
            );
          })
        ) : (
          /* Static placeholder cards — replace with real collection data when articles are published */
          STATIC_ARTICLES.map((art, i) => (
            <article class={`insight-card reveal delay-${(i % 3) * 100}`}>
              <div class="insight-card-meta">
                <span class="insight-category">{art.category}</span>
                <span class="insight-date">{art.date}</span>
              </div>
              <h3 class="insight-title">{art.title}</h3>
              <p class="insight-excerpt">{art.excerpt}</p>
              <div class="insight-footer">
                <span class="insight-read-time">{art.readTime}</span>
                <span class="insight-coming">Coming soon</span>
              </div>
            </article>
          ))
        )}
      </div>

      <!-- Load More — becomes functional when pagination is implemented -->
      <div class="load-more-row">
        <button type="button" class="btn-outline load-more-btn">
          Load More Insights
        </button>
      </div>

    </div>
  </section>

  <!-- INSIGHTS_SECTION_06_FINAL_CTA ───────────────────────────────────────── -->
  <section
    id="insights-final-cta"
    class="section-py-sm bg-gray-950"
    aria-labelledby="insights-cta-heading"
  >
    <div class="container-site">
      <div class="insights-cta-card reveal">
        <div class="insights-cta-inner">
          <span class="eyebrow">Strategic Advisory</span>
          <h2
            id="insights-cta-heading"
            class="insights-cta-heading font-heading font-bold text-white"
          >
            Need to turn AI strategy into measurable execution?
          </h2>
          <p class="insights-cta-body">
            Explore advisory support designed for leaders working on governance,
            operating models and measurable business impact.
          </p>
          <p class="insights-cta-about">
            Explore the strategic background behind these perspectives on the <a href="/about">About page</a>.
          </p>
          <div class="insights-cta-actions">
            <a href="/contact" class="btn-primary">
              Book Advisory Call
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
            <a href="/advisory" class="btn-outline">
              Explore Advisory
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ── SECTION 01: Hero ──────────────────────────────────────────────────── */

  .insights-hero-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: center;
  }

  @media (min-width: 1024px) {
    .insights-hero-layout {
      grid-template-columns: 55fr 45fr;
      gap: 4.5rem;
    }
  }

  .insights-h1 {
    font-size: clamp(1.875rem, 4vw, 2.875rem);
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin: 0.75rem 0 1.5rem;
  }

  .insights-hero-lead {
    font-size: 1.05rem;
    color: rgba(255, 255, 255, 0.68);
    line-height: 1.65;
    max-width: 50ch;
    margin-bottom: 0.85rem;
  }

  .insights-hero-sub {
    font-size: 0.9375rem;
    color: rgba(255, 255, 255, 0.40);
    line-height: 1.65;
    max-width: 48ch;
    margin-bottom: 2rem;
  }

  .insights-hero-cta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.875rem;
    align-items: center;
  }

  .insights-hero-topics {
    margin-top: 1.5rem;
    font-size: 0.78rem;
    color: rgba(255, 255, 255, 0.28);
    letter-spacing: 0.06em;
  }

  /* Hero right: editorial image */
  .insights-hero-visual {
    display: block;
  }

  .insights-hero-image-wrap {
    position: relative;
    border-radius: 1rem;
    overflow: hidden;
    aspect-ratio: 16 / 10;
  }

  @media (min-width: 1024px) {
    .insights-hero-image-wrap {
      aspect-ratio: 4 / 3;
      border-radius: 1.25rem;
    }
  }

  .insights-hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .insights-hero-fade-left {
    position: absolute;
    inset-y: 0;
    left: 0;
    width: 22%;
    background: linear-gradient(to right, #05070D, transparent);
    pointer-events: none;
  }

  .insights-hero-fade-bottom {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 25%;
    background: linear-gradient(to top, #05070D, transparent);
    pointer-events: none;
  }

  /* ── SECTION 02: Featured Insight ─────────────────────────────────────── */

  .featured-card {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    margin-top: 1.75rem;
    padding: 2.25rem;
    border-radius: 1.25rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-top: 2px solid rgba(245, 124, 0, 0.50);
    background: rgba(255, 255, 255, 0.02);
  }

  @media (min-width: 1024px) {
    .featured-card {
      grid-template-columns: 58fr 42fr;
      gap: 4rem;
      align-items: center;
      padding: 3rem 3.5rem;
    }
  }

  .featured-category-badge {
    display: inline-block;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #F57C00;
    border: 1px solid rgba(245, 124, 0, 0.35);
    border-radius: 2rem;
    padding: 0.25rem 0.75rem;
    margin-bottom: 1.25rem;
  }

  .featured-title {
    font-size: clamp(1.5rem, 2.75vw, 2rem);
    line-height: 1.2;
    letter-spacing: -0.01em;
    margin: 0 0 1.25rem;
  }

  .featured-summary {
    font-size: 1rem;
    color: rgba(255, 255, 255, 0.60);
    line-height: 1.70;
    max-width: 52ch;
    margin-bottom: 1.5rem;
  }

  .featured-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 2rem;
    flex-wrap: wrap;
  }

  .featured-date,
  .featured-read-time {
    font-size: 0.82rem;
    color: rgba(255, 255, 255, 0.36);
  }

  .featured-sep {
    color: rgba(255, 255, 255, 0.22);
    font-size: 0.82rem;
  }

  .featured-cta-btn {
    align-self: flex-start;
  }

  /* Featured right: abstract visual */
  .featured-visual {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .featured-visual-inner {
    width: 100%;
    min-height: 220px;
    padding: 1.75rem;
    border-radius: 0.875rem;
    border: 1px solid rgba(255, 255, 255, 0.06);
    background: rgba(0, 0, 0, 0.30);
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .fv-accent {
    width: 2.5rem;
    height: 2px;
    background: rgba(245, 124, 0, 0.60);
    border-radius: 2px;
  }

  .fv-label {
    font-size: 0.68rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(255, 255, 255, 0.27);
  }

  .fv-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.55rem;
  }

  .fv-cell {
    height: 44px;
