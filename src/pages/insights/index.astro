---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { INSIGHT_PILLARS } from '@/data/insightPillars';

const articles = (await getCollection('insights', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const hasArticles = articles.length > 0;

const description =
  'Strategic perspectives on AI strategy, digital transformation, operational excellence and execution discipline for enterprise leaders.';
---

<BaseLayout
  title="Insights"
  description={description}
  canonical="/insights/"
>

  <!-- ── Page Header ──────────────────────────────────────────────────────── -->
  <section class="section-py bg-[#070B14]" aria-labelledby="insights-heading">
    <div class="container-site">
      <span class="eyebrow">Editorial</span>
      <h1
        id="insights-heading"
        class="text-section font-heading font-semibold text-white mt-2 mb-4"
      >
        Insights
      </h1>
      <p class="text-white/60 leading-relaxed max-w-[52ch] text-lg">
        Strategic perspectives on AI strategy, digital transformation, operational
        excellence and execution discipline.
      </p>
    </div>
  </section>

  <!-- ── Four Pillars ─────────────────────────────────────────────────────── -->
  <section class="section-py bg-[#070B14]" aria-labelledby="pillars-heading">
    <div class="container-site">
      <h2 id="pillars-heading" class="sr-only">Editorial categories</h2>
      <div class="insights-pillar-grid">
        {INSIGHT_PILLARS.map((pillar, i) => (
          <a
            href={pillar.href}
            class={`insights-pillar-card reveal delay-${i * 100}`}
            aria-label={`${pillar.title} — explore category`}
          >
            <h3 class="insights-pillar-title">{pillar.title}</h3>
            <p class="insights-pillar-desc">{pillar.description}</p>
            <span class="insights-pillar-cta">
              {pillar.cta}
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Article Listing ──────────────────────────────────────────────────── -->
  <section class="section-py bg-[#070B14]" aria-labelledby="articles-heading">
    <div class="container-site">
      <h2
        id="articles-heading"
        class="font-heading font-semibold text-white text-2xl mb-8"
      >
        {hasArticles ? 'Latest Insights' : 'Coming Soon'}
      </h2>

      {hasArticles ? (
        <div class="articles-grid">
          {articles.map((article) => {
            const date = article.data.pubDate.toLocaleDateString('en-US', {
              year: 'numeric', month: 'long', day: 'numeric',
            });
            return (
              <a
                href={`/insights/${article.slug}/`}
                class="article-card reveal"
                aria-label={`Read: ${article.data.title}`}
              >
                <div class="article-card-meta">
                  <span class="article-category">{article.data.category}</span>
                  <time datetime={article.data.pubDate.toISOString().slice(0, 10)} class="article-date">
                    {date}
                  </time>
                </div>
                <h3 class="article-title">{article.data.title}</h3>
                <p class="article-desc">{article.data.description}</p>
                <span class="article-cta">
                  Read article
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                    <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </span>
              </a>
            );
          })}
        </div>
      ) : (
        <p class="text-white/45 text-base leading-relaxed">
          New strategic insights will be published soon.
        </p>
      )}
    </div>
  </section>

</BaseLayout>

<style>
  .insights-pillar-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }

  @media (min-width: 640px) {
    .insights-pillar-grid { grid-template-columns: 1fr 1fr; }
  }

  @media (min-width: 1024px) {
    .insights-pillar-grid { grid-template-columns: repeat(4, 1fr); }
  }

  .insights-pillar-card {
    display: flex;
    flex-direction: column;
    padding: 1.75rem;
    border-radius: 1rem;
    border: 1px solid rgba(255, 255, 255, 0.07);
    border-top: 2px solid rgba(245, 124, 0, 0.35);
    background: rgba(255, 255, 255, 0.03);
    text-decoration: none;
    transition: background 240ms ease, border-top-color 240ms ease, transform 240ms ease, box-shadow 240ms ease;
  }

  .insights-pillar-card:hover {
    background: rgba(255, 255, 255, 0.055);
    border-top-color: rgba(245, 124, 0, 0.8);
    transform: translateY(-3px);
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.45);
  }

  .insights-pillar-title {
    font-family: Manrope, system-ui, sans-serif;
    font-size: 1.1rem;
    font-weight: 700;
    color: #ffffff;
    margin: 0 0 0.75rem;
  }

  .insights-pillar-desc {
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.52);
    line-height: 1.65;
    margin: 0 0 auto;
    padding-bottom: 1.25rem;
  }

  .insights-pillar-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.82rem;
    font-weight: 700;
    color: rgba(245, 124, 0, 0.75);
    transition: color 180ms ease, gap 180ms ease;
  }

  .insights-pillar-card:hover .insights-pillar-cta {
    color: #F57C00;
    gap: 0.6rem;
  }

  /* Article grid */
  .articles-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }

  @media (min-width: 768px) {
    .articles-grid { grid-template-columns: 1fr 1fr; }
  }

  @media (min-width: 1280px) {
    .articles-grid { grid-template-columns: repeat(3, 1fr); }
  }

  .article-card {
    display: flex;
    flex-direction: column;
    padding: 1.75rem;
    border-radius: 1rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.03);
    text-decoration: none;
    transition: background 240ms ease, border-color 240ms ease, transform 240ms ease, box-shadow 240ms ease;
  }

  .article-card:hover {
    background: rgba(255, 255, 255, 0.055);
    border-color: rgba(255, 255, 255, 0.14);
    transform: translateY(-3px);
    box-shadow: 0 16px 48px rgba(0, 0, 0, 0.4);
  }

  .article-card-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.85rem;
    flex-wrap: wrap;
  }

  .article-category {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #F57C00;
  }

  .article-date {
    font-size: 0.78rem;
    color: rgba(255, 255, 255, 0.38);
  }

  .article-title {
    font-family: Manrope, system-ui, sans-serif;
    font-size: 1.05rem;
    font-weight: 700;
    color: #ffffff;
    line-height: 1.3;
    margin: 0 0 0.75rem;
  }

  .article-desc {
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.52);
    line-height: 1.65;
    margin: 0 0 auto;
    padding-bottom: 1.25rem;
  }

  .article-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.82rem;
    font-weight: 700;
    color: rgba(255, 255, 255, 0.5);
    transition: color 180ms ease, gap 180ms ease;
  }

  .article-card:hover .article-cta {
    color: rgba(245, 124, 0, 0.9);
    gap: 0.6rem;
  }
</style>
