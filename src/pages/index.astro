---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { SITE } from '@/data/site';
import { ADVISORY_PILLARS } from '@/data/advisoryPillars';
import { KPIS } from '@/data/kpis';
---

<BaseLayout
  title="AI Strategy & Enterprise Transformation Advisor"
  description={SITE.description}
>

  <!-- ── 1. Hero — Cinematic dark ──────────────────────────────────────────── -->
  <section
    class="relative min-h-[92svh] flex items-center bg-[#070B14] overflow-hidden"
    aria-label="Hero"
  >
    <!-- Background visual layers -->
    <div class="absolute inset-0 pointer-events-none select-none" aria-hidden="true">

      <!-- AI network texture -->
      <div class="absolute inset-0 bg-[url('/assets/backgrounds/hero-ai-network-bg.svg')] bg-cover opacity-[0.025]"></div>

      <!-- Portrait: right-side, bleeds full height, no container border -->
      <div class="absolute inset-y-0 right-0 w-full lg:w-[56%]">
        <img
          src="/assets/portraits/facundo-hero-executive.webp"
          alt=""
          width="800"
          height="1040"
          class="absolute inset-0 w-full h-full object-cover object-top"
          loading="eager"
          decoding="async"
        />
        <!-- Left: portrait fades into the dark background -->
        <div class="absolute inset-y-0 left-0 w-3/4 bg-gradient-to-r from-[#070B14] via-[#070B14]/80 to-transparent"></div>
        <!-- Bottom: fade out -->
        <div class="absolute bottom-0 left-0 right-0 h-48 bg-gradient-to-t from-[#070B14] to-transparent"></div>
        <!-- Top: subtle fade -->
        <div class="absolute top-0 left-0 right-0 h-24 bg-gradient-to-b from-[#070B14]/50 to-transparent"></div>
      </div>

      <!-- Cyan atmospheric glow — AI accent -->
      <div class="absolute top-0 right-0 w-1/2 h-full bg-[radial-gradient(ellipse_70%_65%_at_85%_30%,rgba(0,217,255,0.07)_0%,transparent_70%)]"></div>

      <!-- Mobile: solid overlay so text remains readable over the portrait -->
      <div class="absolute inset-0 bg-[#070B14]/65 lg:hidden"></div>
    </div>

    <!-- Content — left-anchored, max 580px -->
    <div class="container-site relative z-10 py-24 lg:py-28">
      <div class="max-w-[580px]">

        <span class="eyebrow reveal">AI Strategy · Enterprise Transformation</span>

        <h1 class="text-hero font-heading font-extrabold text-white mt-4 mb-6 reveal">
          Transforming ambition<br />
          into results.
        </h1>

        <p class="text-white/65 text-lg leading-relaxed max-w-[46ch] mb-8 reveal delay-100">
          Executive advisory for AI Strategy, Digital Transformation and Intelligent Operating Models.
          I help organizations evolve with clarity, structure and measurable impact.
        </p>

        <!-- Pull quote -->
        <blockquote class="border-l-2 border-orange-500/50 pl-5 mb-8 max-w-[44ch] reveal delay-100">
          <p class="text-white/50 text-sm leading-snug italic">
            The future belongs to organizations that combine intelligence, adaptability and execution.
          </p>
        </blockquote>

        <!-- CTAs -->
        <div class="flex flex-wrap gap-3 reveal delay-200">
          <a href="/contact" class="btn-primary">
            Book an Advisory Call
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <a href="/advisory" class="btn-outline">
            Explore Services
          </a>
        </div>

      </div>
    </div>
  </section>

  <!-- ── 2. Advisory Grid — Dark foundation ────────────────────────────────── -->
  <section
    class="section-py bg-[#070B14]"
    aria-labelledby="advisory-heading"
  >
    <div class="container-site">
      <div class="section-header-split mb-10 lg:mb-12">
        <div>
          <span class="eyebrow" style="color: var(--color-orange);">Strategic Advisory</span>
          <h2 id="advisory-heading" class="text-section font-heading font-semibold text-white mt-1">
            Strategic advisory for<br class="hidden md:block" />intelligent transformation.
          </h2>
        </div>
        <p class="text-white/55 leading-relaxed max-w-[38ch] md:pt-10">
          Four interconnected advisory practices that help organizations move from AI ambition to operating model reality.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {ADVISORY_PILLARS.map((pillar, i) => (
          <a
            href={pillar.href}
            class={`card-dark group reveal delay-${i * 100}`}
            aria-label={`Learn more about ${pillar.title}`}
          >
            <!-- Icon -->
            <div class="w-11 h-11 rounded-lg bg-orange-500/10 border border-orange-500/20 flex items-center justify-center mb-4">
              <svg width="22" height="22" viewBox="0 0 22 22" fill="none" aria-hidden="true">
                <circle cx="11" cy="11" r="7" stroke="#F57C00" stroke-width="1.5"/>
                <path d="M8 11h6M11 8v6" stroke="#F57C00" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
            </div>
            <h3 class="font-heading font-semibold text-white text-lg mb-2">{pillar.title}</h3>
            <p class="text-sm text-orange-400 font-medium mb-3 italic">{pillar.outcome}</p>
            <p class="text-white/55 text-sm leading-relaxed mb-4">{pillar.description}</p>
            <span class="text-link-light text-sm">
              Learn more
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true" class="transition-transform group-hover:translate-x-1">
                <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ── 3. Industries Served — Asymmetric editorial grid ─────────────────── -->
  <section
    class="section-py bg-[#070B14]"
    aria-labelledby="industries-heading"
  >
    <div class="container-site">

      <!-- Header -->
      <div class="mb-10 lg:mb-12">
        <span class="eyebrow">Sectors</span>
        <h2 id="industries-heading" class="text-section font-heading font-semibold text-white mt-1 mb-4">
          Industries Served
        </h2>
        <p class="text-white/55 leading-relaxed max-w-[56ch]">
          Deep domain expertise combined with cross-industry transformation experience to connect AI strategy, operating models and execution with measurable business impact.
        </p>
      </div>

      <!-- Asymmetric grid -->
      <div class="industries-grid">

        <!-- Banking & Financial Services — dominant left card -->
        <article class="industries-card industries-card-banking reveal">
          <img
            src="/images/industries/industry-banking-financial-services.webp"
            alt="AI-powered banking and financial services transformation with executive dashboards and digital finance signals."
            loading="lazy"
            decoding="async"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-[#070B14]/90 via-[#070B14]/30 to-transparent"></div>
          <div class="absolute bottom-0 left-0 right-0 p-7 lg:p-8">
            <p class="industries-eyebrow">Financial Services</p>
            <h3 class="font-heading font-bold text-white text-xl lg:text-2xl mb-2 leading-tight">
              Banking & Financial Services
            </h3>
            <p class="text-white/65 text-sm leading-relaxed max-w-[38ch]">
              AI strategy, agile operating models, portfolio governance and execution discipline for banking and financial institutions.
            </p>
          </div>
        </article>

        <!-- Technology & Product Organizations — wide upper-right card -->
        <article class="industries-card industries-card-technology reveal delay-100">
          <img
            src="/images/industries/industry-technology-product-organizations-transformation.webp"
            alt="AI-powered technology and product organization transformation with platform analytics and product execution signals."
            loading="lazy"
            decoding="async"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-[#070B14]/90 via-[#070B14]/30 to-transparent"></div>
          <div class="absolute bottom-0 left-0 right-0 p-6">
            <p class="industries-eyebrow">Tech & Product</p>
            <h3 class="font-heading font-bold text-white text-lg mb-2 leading-tight">
              Technology & Product Organizations
            </h3>
            <p class="text-white/65 text-sm leading-relaxed max-w-[52ch]">
              Product transformation, platform strategy, delivery governance and scalable execution models for technology-driven organizations.
            </p>
          </div>
        </article>

        <!-- Insurance & Risk Management — lower-right, first half -->
        <article class="industries-card industries-card-insurance reveal delay-200">
          <img
            src="/images/industries/industry-insurance-risk-management.webp"
            alt="AI-powered insurance and risk management command center with predictive analytics and enterprise governance signals."
            loading="lazy"
            decoding="async"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-[#070B14]/90 via-[#070B14]/35 to-transparent"></div>
          <div class="absolute bottom-0 left-0 right-0 p-5">
            <p class="industries-eyebrow">Insurance</p>
            <h3 class="font-heading font-semibold text-white text-base mb-1 leading-tight">
              Insurance & Risk Management
            </h3>
            <p class="text-white/60 text-xs leading-relaxed">
              Risk intelligence, operational control and transformation governance for insurance organizations.
            </p>
          </div>
        </article>

        <!-- Operational Excellence & Transformation — lower-right, second half -->
        <article class="industries-card industries-card-operations reveal delay-300">
          <img
            src="/images/industries/industry-operational-excellence-transformation.webp"
            alt="Executive operational excellence meeting with AI-assisted OKR dashboards, QBR metrics and business transformation signals."
            loading="lazy"
            decoding="async"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-[#070B14]/90 via-[#070B14]/35 to-transparent"></div>
          <div class="absolute bottom-0 left-0 right-0 p-5">
            <p class="industries-eyebrow">Operations</p>
            <h3 class="font-heading font-semibold text-white text-base mb-1 leading-tight">
              Operational Excellence & Transformation
            </h3>
            <p class="text-white/60 text-xs leading-relaxed">
              OKRs, QBRs, process alignment, execution systems and continuous improvement for enterprise transformation.
            </p>
          </div>
        </article>

      </div>
    </div>
  </section>

  <!-- ── 4. Metrics & Proof Points ────────────────────────────────────────── -->
  <section
    id="metrics-section"
    class="relative section-py bg-[#070B14] overflow-hidden"
    aria-labelledby="metrics-heading"
  >
    <!-- Background: subtle elevation gradient at top -->
    <div class="absolute inset-0 bg-gradient-to-b from-[#0D1829]/50 via-[#0A101A]/20 to-transparent pointer-events-none" aria-hidden="true"></div>
    <!-- Top separator: feathered line -->
    <div class="absolute top-0 inset-x-0 h-px bg-gradient-to-r from-transparent via-white/[0.10] to-transparent pointer-events-none" aria-hidden="true"></div>
    <!-- Warm orange radial glow — anchors section to brand accent -->
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-3/4 h-40 bg-[radial-gradient(ellipse_at_top,rgba(245,124,0,0.05)_0%,transparent_70%)] pointer-events-none" aria-hidden="true"></div>

    <div class="container-site relative z-10">
      <h2 id="metrics-heading" class="sr-only">Experience and authority</h2>
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-5">
        {KPIS.map((kpi) => {
          const isNumeric = /^\d/.test(kpi.value);
          const num = isNumeric ? parseInt(kpi.value, 10) : null;
          const suffix = isNumeric ? kpi.value.replace(/^\d+/, '') : undefined;
          return (
            <div class="kpi-cell px-6 py-10 text-center reveal">
              <div
                class="font-heading font-bold text-5xl lg:text-6xl text-orange-500 mb-3 leading-none tabular-nums"
                data-kpi-value={kpi.value}
                data-counter={isNumeric ? String(num) : undefined}
                data-suffix={suffix}
                aria-label={`${kpi.value} ${kpi.label}`}
              >
                {kpi.value}
              </div>
              <p class="text-white font-semibold text-sm mb-1">{kpi.label}</p>
              {kpi.sublabel && (
                <p class="text-white/45 text-xs leading-relaxed">{kpi.sublabel}</p>
              )}
            </div>
          );
        })}
      </div>
    </div>
  </section>


<script>
  // Scroll-triggered count-up animation for numeric metrics.
  // Runs once when the metrics section enters the viewport.
  // Respects prefers-reduced-motion: shows final values immediately.
  (function () {
    if (typeof window === 'undefined') return;

    const section = document.getElementById('metrics-section');
    if (!section) return;

    const counters = Array.from(section.querySelectorAll<HTMLElement>('[data-counter]'));
    if (counters.length === 0) return;

    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (prefersReduced) return; // final values already rendered in HTML

    const DURATION = 1600;
    const easeOut = (t: number) => 1 - Math.pow(1 - t, 3);

    function runCounter(el: HTMLElement) {
      const target = parseInt(el.dataset.counter ?? '0', 10);
      const suffix = el.dataset.suffix ?? '';
      const start = performance.now();

      function tick(now: number) {
        const progress = Math.min((now - start) / DURATION, 1);
        el.textContent = String(Math.round(easeOut(progress) * target)) + suffix;
        if (progress < 1) requestAnimationFrame(tick);
        else el.textContent = String(target) + suffix;
      }

      requestAnimationFrame(tick);
    }

    const observer = new IntersectionObserver(
      (entries) => {
        if (entries[0].isIntersecting) {
          counters.forEach(runCounter);
          observer.disconnect();
        }
      },
      { threshold: 0.3 }
    );

    observer.observe(section);
  })();
</script>

</BaseLayout>
