---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { SITE } from '@/data/site';
import { ADVISORY_PILLARS } from '@/data/advisoryPillars';
import { KPIS } from '@/data/kpis';
import StrategicPerspectives from '@/components/sections/StrategicPerspectives.astro';
import ProofLogoBanner from '@/components/sections/ProofLogoBanner.astro';

/*
 * Advisory card icons — inline SVG strings, one per pillar in ADVISORY_PILLARS order.
 * 28×28 viewport, stroke="currentColor" — inherits CSS color for hover transitions.
 * Stroke weights 1.4/1.2 match Insights icon system. Scale factor 28/28 (native).
 */
const ADVISORY_ICONS: string[] = [
  // 01 — AI Strategy: hub-satellite — neural network, 3 satellite nodes + central hub
  `<svg width="28" height="28" viewBox="0 0 28 28" fill="none" aria-hidden="true">
    <circle cx="14"   cy="3.5"  r="2.1" stroke="currentColor" stroke-width="1.4"/>
    <circle cx="23.1" cy="19.6" r="2.1" stroke="currentColor" stroke-width="1.4"/>
    <circle cx="4.9"  cy="19.6" r="2.1" stroke="currentColor" stroke-width="1.4"/>
    <circle cx="14"   cy="14"   r="2.6" stroke="currentColor" stroke-width="1.4"/>
    <line x1="14"   y1="5.6"  x2="14"   y2="11.4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
    <line x1="21.4" y1="18.1" x2="16.3" y2="15.4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
    <line x1="6.6"  y1="18.1" x2="11.7" y2="15.4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
  </svg>`,

  // 02 — Digital Transformation: stacked diamond layers — operating model evolution
  `<svg width="28" height="28" viewBox="0 0 28 28" fill="none" aria-hidden="true">
    <path d="M14 3L26 9L14 15L2 9Z"   stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/>
    <path d="M2 14L14 20L26 14"       stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
    <path d="M2 19L14 25L26 19"       stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
  </svg>`,

  // 03 — Operational Excellence: ascending bars — execution performance and continuous improvement
  `<svg width="28" height="28" viewBox="0 0 28 28" fill="none" aria-hidden="true">
    <rect x="3"  y="17" width="5" height="8"  rx="1" stroke="currentColor" stroke-width="1.4"/>
    <rect x="11" y="11" width="5" height="14" rx="1" stroke="currentColor" stroke-width="1.4"/>
    <rect x="19" y="4"  width="5" height="21" rx="1" stroke="currentColor" stroke-width="1.4"/>
    <line x1="3" y1="24.5" x2="25" y2="24.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
  </svg>`,

  // 04 — AI Adoption: concentric target — structured progression to embedded AI
  `<svg width="28" height="28" viewBox="0 0 28 28" fill="none" aria-hidden="true">
    <circle cx="14" cy="14" r="11.5" stroke="currentColor" stroke-width="1.4"/>
    <circle cx="14" cy="14" r="6.5"  stroke="currentColor" stroke-width="1.4"/>
    <circle cx="14" cy="14" r="2.2"  fill="currentColor"/>
  </svg>`,
];
---

<BaseLayout
  title="AI Strategy &amp; Transformation Advisor"
  description={SITE.description}
  canonical="/"
  preloadImage="/assets/portraits/facundo-hero-executive.webp"
  structuredData={[
    {
      '@context': 'https://schema.org',
      '@type': 'WebSite',
      name: 'Facundo Gangemi',
      url: 'https://facundogangemi.com',
      description: SITE.description,
    },
    {
      '@context': 'https://schema.org',
      '@type': 'ProfessionalService',
      '@id': 'https://facundogangemi.com/#professional-service',
      name: 'Facundo Gangemi',
      url: 'https://facundogangemi.com',
      description: 'Executive advisory for AI Strategy, Digital Transformation and Operating Models — helping enterprise leaders build clarity, execution and measurable business impact.',
      areaServed: ['Europe', 'Latin America'],
      serviceType: [
        'AI Strategy Advisory',
        'Digital Transformation Advisory',
        'Operational Excellence Advisory',
        'Operating Model Transformation',
        'AI Adoption Advisory',
      ],
    },
  ]}
>

  <!-- ── 1. Hero — Cinematic dark ──────────────────────────────────────────── -->
  <section
    class="relative min-h-[78svh] flex items-center bg-[#05070D] overflow-hidden"
    aria-label="Hero"
  >
    <!-- Background visual layers -->
    <div class="absolute inset-0 pointer-events-none select-none" aria-hidden="true">

      <!-- Portrait: right-side, bleeds full height, no container border -->
      <div class="absolute inset-y-0 right-0 w-full lg:w-[56%]">
        <img
          src="/assets/portraits/facundo-hero-executive.webp"
          alt=""
          width="800"
          height="1040"
          class="absolute inset-0 w-full h-full object-cover object-top"
          loading="eager"
          decoding="async"
        />
        <!-- Left: portrait fades into the dark background -->
        <div class="absolute inset-y-0 left-0 w-3/4 bg-gradient-to-r from-[#05070D] via-[#05070D]/80 to-transparent"></div>
        <!-- Bottom: fade out -->
        <div class="absolute bottom-0 left-0 right-0 h-48 bg-gradient-to-t from-[#05070D] to-transparent"></div>
        <!-- Top: subtle fade -->
        <div class="absolute top-0 left-0 right-0 h-24 bg-gradient-to-b from-[#05070D]/50 to-transparent"></div>
      </div>

      <!-- Cyan atmospheric glow — AI accent -->
      <div class="absolute top-0 right-0 w-1/2 h-full bg-[radial-gradient(ellipse_70%_65%_at_85%_30%,rgba(0,217,255,0.07)_0%,transparent_70%)]"></div>

      <!-- Mobile: solid overlay so text remains readable over the portrait -->
      <div class="absolute inset-0 bg-[#05070D]/65 lg:hidden"></div>
    </div>

    <!-- Content — left-anchored, max 580px -->
    <div class="container-site relative z-10 py-16 lg:py-20">
      <div class="max-w-[580px]">

        <span class="eyebrow reveal">AI Strategy · Enterprise Transformation</span>

        <h1 class="text-hero font-heading font-extrabold text-white mt-4 mb-6 reveal">
          AI Strategy &amp;<br />
          Digital Transformation Advisory.
        </h1>

        <p class="text-white/65 text-lg leading-relaxed max-w-[46ch] mb-8 reveal delay-100">
          Executive advisory for AI Strategy, Digital Transformation and Intelligent Operating Models.
          I help organizations evolve with clarity, structure and measurable impact.
        </p>

        <!-- Pull quote -->
        <blockquote class="border-l-2 border-orange-500/50 pl-5 mb-8 max-w-[44ch] reveal delay-100">
          <p class="text-white/50 text-sm leading-snug italic">
            AI adoption fails when it is treated as a tool rollout instead of an operating model redesign.
          </p>
        </blockquote>

        <!-- CTAs -->
        <div class="flex flex-wrap gap-3 reveal delay-200">
          <a href="/contact/" class="btn-primary">
            Book an Advisory Call
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <a href="/advisory/" class="btn-outline">
            Explore Services
          </a>
        </div>

      </div>
    </div>
  </section>

  <!-- ── 2. Authority & Proof — Enterprise logo band ──────────────────────── -->
  <ProofLogoBanner />

  <!-- ── 3. Advisory Grid — Dark foundation ────────────────────────────────── -->
  <section
    class="section-py bg-[#080A10]"
    aria-labelledby="advisory-heading"
  >
    <div class="container-site">
      <div class="section-header-split mb-10 lg:mb-12">
        <div>
          <span class="eyebrow" style="color: var(--color-orange);">Strategic Advisory</span>
          <h2 id="advisory-heading" class="text-section font-heading font-semibold text-white mt-1">
            Strategic advisory for<br class="hidden md:block" />intelligent transformation.
          </h2>
        </div>
        <p class="text-white/55 leading-relaxed max-w-[38ch] md:pt-10">
          Four interconnected advisory practices that help organizations move from AI ambition to operating model reality.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {ADVISORY_PILLARS.map((pillar, i) => (
          <a
            href={pillar.href}
            class={`card-dark card-adv group reveal delay-${i * 100}`}
            aria-label={`Learn more about ${pillar.title}`}
          >
            <!-- Icon -->
            <div class="adv-icon" aria-hidden="true" set:html={ADVISORY_ICONS[i]} />
            <h3 class="font-heading font-semibold text-white text-lg mb-2">{pillar.title}</h3>
            <p class="text-sm text-orange-400 font-semibold mb-3">{pillar.outcome}</p>
            <p class="text-white/55 text-sm leading-relaxed">{pillar.description}</p>
            <span class="text-link-light text-sm adv-cta">
              Learn more
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true" class="adv-cta-arrow">
                <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ── 4. Signature Framework — Methodology ─────────────────────────────── -->
  <section
    class="section-py bg-gray-950"
    aria-labelledby="sf-heading"
  >
    <div class="container-site">
      <div class="sf-layout reveal">

        <!-- Left: editorial header -->
        <div>
          <span class="eyebrow">Signature Framework</span>
          <h2 id="sf-heading" class="text-section font-heading font-semibold text-white mt-1 mb-4">
            A structured path from AI ambition<br class="hidden lg:block" />
            to operating model reality.
          </h2>
          <p class="sf-body">
            Every advisory engagement follows a proven four-phase process. Not a template, but a discipline refined across complex enterprise transformations in banking, technology, insurance and operations.
          </p>
          <a href="/advisory/" class="sf-cta-link">
            Explore Advisory Practices
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>

        <!-- Right: four steps -->
        <div class="sf-steps">

          <div class="sf-step">
            <div class="sf-step-num font-heading" aria-hidden="true">01</div>
            <p class="sf-step-phase">Discover</p>
            <h3 class="sf-step-title font-heading">Strategic Clarity</h3>
            <p class="sf-step-body">Diagnose the current state. Identify AI readiness gaps, operating model constraints and the misalignments that prevent meaningful progress.</p>
          </div>

          <div class="sf-step">
            <div class="sf-step-num font-heading" aria-hidden="true">02</div>
            <p class="sf-step-phase">Design</p>
            <h3 class="sf-step-title font-heading">Architecture</h3>
            <p class="sf-step-body">Design the future operating model. Define the AI strategy, governance structure, capability roadmap and organizational design required for sustained transformation.</p>
          </div>

          <div class="sf-step">
            <div class="sf-step-num font-heading" aria-hidden="true">03</div>
            <p class="sf-step-phase">Deploy</p>
            <h3 class="sf-step-title font-heading">Execution</h3>
            <p class="sf-step-body">Execute with discipline. Implement governance frameworks, delivery systems, OKRs and transformation programs that convert strategy into organizational behavior.</p>
          </div>

          <div class="sf-step">
            <div class="sf-step-num font-heading" aria-hidden="true">04</div>
            <p class="sf-step-phase">Evolve</p>
            <h3 class="sf-step-title font-heading">Continuity</h3>
            <p class="sf-step-body">Embed continuous improvement. Establish measurement cycles, leadership feedback loops and adaptive mechanisms that make transformation sustainable, not a one-time event.</p>
          </div>

        </div>
      </div>
    </div>
  </section>

  <!-- ── 5. Industries Served — Asymmetric editorial grid ─────────────────── -->
  <section
    class="section-py bg-[#05070D]"
    aria-labelledby="industries-heading"
  >
    <div class="container-site">

      <!-- Header -->
      <div class="mb-10 lg:mb-12">
        <span class="eyebrow">Sectors</span>
        <h2 id="industries-heading" class="text-section font-heading font-semibold text-white mt-1 mb-4">
          Industries Served
        </h2>
        <p class="text-white/55 leading-relaxed max-w-[56ch]">
          Deep domain expertise combined with cross-industry transformation experience to connect AI strategy, operating models and execution with measurable business impact.
        </p>
      </div>

      <!-- Asymmetric grid -->
      <div class="industries-grid">

        <!-- Banking & Financial Services — dominant left card -->
        <article class="industries-card industries-card-banking reveal">
          <img
            src="/images/industries/industry-banking-financial-services.webp"
            alt="AI-powered banking and financial services transformation with executive dashboards and digital finance signals."
            loading="lazy"
            decoding="async"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-[#05070D]/90 via-[#05070D]/30 to-transparent"></div>
          <div class="absolute bottom-0 left-0 right-0 p-7 lg:p-8">
            <p class="industries-eyebrow">Financial Services</p>
            <h3 class="font-heading font-bold text-white text-xl lg:text-2xl mb-2 leading-tight">
              Banking & Financial Services
            </h3>
            <p class="text-white/65 text-sm leading-relaxed max-w-[38ch]">
              AI strategy, agile operating models, portfolio governance and execution discipline for banking and financial institutions.
            </p>
          </div>
        </article>

        <!-- Technology & Product Organizations — wide upper-right card -->
        <article class="industries-card industries-card-technology reveal delay-100">
          <img
            src="/images/industries/industry-technology-product-organizations-transformation.webp"
            alt="AI-powered technology and product organization transformation with platform analytics and product execution signals."
            loading="lazy"
            decoding="async"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-[#05070D]/90 via-[#05070D]/30 to-transparent"></div>
          <div class="absolute bottom-0 left-0 right-0 p-6">
            <p class="industries-eyebrow">Tech & Product</p>
            <h3 class="font-heading font-bold text-white text-lg mb-2 leading-tight">
              Technology & Product Organizations
            </h3>
            <p class="text-white/65 text-sm leading-relaxed max-w-[52ch]">
              Product transformation, platform strategy, delivery governance and scalable execution models for technology-driven organizations.
            </p>
          </div>
        </article>

        <!-- Insurance & Risk Management — lower-right, first half -->
        <article class="industries-card industries-card-insurance reveal delay-200">
          <img
            src="/images/industries/industry-insurance-risk-management.webp"
            alt="AI-powered insurance and risk management command center with predictive analytics and enterprise governance signals."
            loading="lazy"
            decoding="async"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-[#05070D]/90 via-[#05070D]/35 to-transparent"></div>
          <div class="absolute bottom-0 left-0 right-0 p-5">
            <p class="industries-eyebrow">Insurance</p>
            <h3 class="font-heading font-semibold text-white text-base mb-1 leading-tight">
              Insurance & Risk Management
            </h3>
            <p class="text-white/60 text-xs leading-relaxed">
              Risk intelligence, operational control and transformation governance for insurance organizations.
            </p>
          </div>
        </article>

        <!-- Operational Excellence & Transformation — lower-right, second half -->
        <article class="industries-card industries-card-operations reveal delay-300">
          <img
            src="/images/industries/industry-operational-excellence-transformation.webp"
            alt="Executive operational excellence meeting with AI-assisted OKR dashboards, QBR metrics and business transformation signals."
            loading="lazy"
            decoding="async"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-[#05070D]/90 via-[#05070D]/35 to-transparent"></div>
          <div class="absolute bottom-0 left-0 right-0 p-5">
            <p class="industries-eyebrow">Operations</p>
            <h3 class="font-heading font-semibold text-white text-base mb-1 leading-tight">
              Operational Excellence & Transformation
            </h3>
            <p class="text-white/60 text-xs leading-relaxed">
              OKRs, QBRs, process alignment, execution systems and continuous improvement for enterprise transformation.
            </p>
          </div>
        </article>

      </div>
    </div>
  </section>

  <!-- ── 6. Metrics & Proof Points ────────────────────────────────────────── -->
  <section
    id="metrics-section"
    class="relative section-py-xs bg-[#05070D] overflow-hidden"
    aria-labelledby="metrics-heading"
  >
    <!-- Background: subtle elevation gradient at top -->
    <div class="absolute inset-0 bg-gradient-to-b from-[#0C0E13]/18 via-[#08090D]/10 to-transparent pointer-events-none" aria-hidden="true"></div>
    <!-- Top separator: feathered line -->
    <div class="absolute top-0 inset-x-0 h-px bg-gradient-to-r from-transparent via-white/[0.10] to-transparent pointer-events-none" aria-hidden="true"></div>
    <!-- Bottom separator: feathered line -->
    <div class="absolute bottom-0 inset-x-0 h-px bg-gradient-to-r from-transparent via-white/[0.08] to-transparent pointer-events-none" aria-hidden="true"></div>
    <!-- Warm orange radial glow — anchors section to brand accent -->
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-3/4 h-40 bg-[radial-gradient(ellipse_at_top,rgba(245,124,0,0.05)_0%,transparent_70%)] pointer-events-none" aria-hidden="true"></div>

    <div class="container-site relative z-10">
      <h2 id="metrics-heading" class="sr-only">Experience and authority</h2>
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-5">
        {KPIS.map((kpi) => {
          const isNumeric = /^\d/.test(kpi.value);
          const num = isNumeric ? parseInt(kpi.value, 10) : null;
          const suffix = isNumeric ? kpi.value.replace(/^\d+/, '') : undefined;
          return (
            <div class="kpi-cell px-6 py-10 text-center reveal">
              <div
                class="font-heading font-bold text-5xl lg:text-6xl text-orange-500 mb-3 leading-none tabular-nums"
                data-kpi-value={kpi.value}
                data-counter={isNumeric ? String(num) : undefined}
                data-suffix={suffix}
                aria-label={`${kpi.value} ${kpi.label}`}
              >
                {kpi.value}
              </div>
              <p class="text-white font-semibold text-sm mb-1">{kpi.label}</p>
              {kpi.sublabel && (
                <p class="text-white/45 text-xs leading-relaxed">{kpi.sublabel}</p>
              )}
            </div>
          );
        })}
      </div>
    </div>
  </section>

<script>
  // Scroll-triggered count-up animation for numeric metrics.
  // Runs once when the metrics section enters the viewport.
  // Respects prefers-reduced-motion: shows final values immediately.
  (function () {
    if (typeof window === 'undefined') return;

    const section = document.getElementById('metrics-section');
    if (!section) return;

    const counters = Array.from(section.querySelectorAll<HTMLElement>('[data-counter]'));
    if (counters.length === 0) return;

    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (prefersReduced) return; // final values already rendered in HTML

    const DURATION = 1600;
    const easeOut = (t: number) => 1 - Math.pow(1 - t, 3);

    function runCounter(el: HTMLElement) {
      const target = parseInt(el.dataset.counter ?? '0', 10);
      const suffix = el.dataset.suffix ?? '';
      const start = performance.now();

      function tick(now: number) {
        const progress = Math.min((now - start) / DURATION, 1);
        el.textContent = String(Math.round(easeOut(progress) * target)) + suffix;
        if (progress < 1) requestAnimationFrame(tick);
        else el.textContent = String(target) + suffix;
      }

      requestAnimationFrame(tick);
    }

    const observer = new IntersectionObserver(
      (entries) => {
        if (entries[0].isIntersecting) {
          counters.forEach(runCounter);
          observer.disconnect();
        }
      },
      { threshold: 0.3 }
    );

    observer.observe(section);
  })();
</script>

  <!-- ── 7. Transformation in Practice ────────────────────────────────────── -->
  <section
    class="section-py-sm bg-gray-950"
    aria-labelledby="tip-heading"
  >
    <div class="container-site">

      <!-- Section header -->
      <div class="mb-8 lg:mb-10">
        <span class="eyebrow">Applied AI Transformation</span>
        <h2 id="tip-heading" class="text-section font-heading font-semibold text-white mt-1">
          Transformation in Practice
        </h2>
      </div>

      <!-- Financial Services case card -->
      <article class="tip-card reveal" aria-label="Financial services transformation case">

        <!-- Left orange accent bar -->
        <div class="tip-bar" aria-hidden="true"></div>

        <!-- Card body -->
        <div class="tip-body">

          <!-- Case content -->
          <div class="tip-content">

            <!-- Tag + Headline -->
            <div>
              <p class="tip-tag">BANKING &amp; FINANCIAL SERVICES · AI-ENABLED ENGINEERING GOVERNANCE</p>
              <h3 class="tip-headline font-heading">
                From manual quality control to AI-enabled software governance
              </h3>
            </div>

            <!-- Challenge + Outcome -->
            <div class="tip-detail">
              <div>
                <p class="tip-label">Challenge</p>
                <p class="tip-text">At enterprise scale, inconsistent quality controls across software delivery increased regulatory, security and operational risk for technology leadership.</p>
              </div>
              <div>
                <p class="tip-label">Outcome</p>
                <p class="tip-text">The organization moved from manual, late-stage quality control to an AI-enabled governance loop inside the software delivery governance workflow, giving teams earlier visibility into quality, security and compliance gaps before they became delivery risks. Improvement was tracked through AI-reviewed pull requests, recurring findings and correction cycles.</p>
              </div>
            </div>

            <!-- Card CTA -->
            <div>
              <a href="/contact/" class="sf-cta-link">
                Discuss a similar transformation
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                  <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
            </div>

          </div>

          <!-- AI-Enabled Delivery Loop diagram -->
          <figure class="tip-diagram-col" aria-hidden="true">
            <p class="tip-diagram-title">AI-Enabled Governance Loop</p>
            <p class="tip-diagram-sub">Quality · Security · Compliance · Efficiency</p>
            <!--
              Circular flow diagram — AI-enabled pull request governance cycle.
              Center: (170,138), track radius: 90. ViewBox: 340×280.
              Nodes at 60° intervals from top, clockwise:
                n0 PR Submitted (−90°): (170,48)
                n1 AI Review    (−30°): (248,93)
                n2 Findings     (+30°): (248,183)
                n3 Developer Fix(+90°): (170,228)
                n4 Re-check    (+150°): (92,183)
                n5 Learning Loop(+210°): (92,93)
            -->
            <svg viewBox="0 0 340 280" fill="none" xmlns="http://www.w3.org/2000/svg" class="tip-svg" focusable="false">

              <!-- Inner circle — intentional center node with orange presence -->
              <circle class="tip-gi" cx="170" cy="138" r="40" fill="rgba(245,124,0,0.09)" stroke="rgba(245,124,0,0.40)" stroke-width="1"/>

              <!-- Outer track — dashed guide circle -->
              <circle cx="170" cy="138" r="90" stroke="rgba(255,255,255,0.14)" stroke-width="1" stroke-dasharray="3 7"/>

              <!-- ── Arc segments ── -->
              <!-- 0→1 PR Submitted → AI Review — orange highlight -->
              <path class="tip-ga" d="M170,48 A90,90 0 0,1 248,93" stroke="rgba(245,124,0,0.68)" stroke-width="1.5"/>
              <!-- 1→2 AI Review → Findings -->
              <path class="tip-gn-neutral" d="M248,93 A90,90 0 0,1 248,183" stroke="rgba(255,255,255,0.28)" stroke-width="1.2"/>
              <!-- 2→3 Findings → Developer Fix -->
