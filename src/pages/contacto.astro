---
/**
 * Legacy URL redirect: /contacto/ → /contact/
 * Static compatibility page for WordPress URL migration
 */

const destination = '/contact/';
const canonicalUrl = 'https://facundogangemi.com' + destination;
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Redirección - Contacto | Facundo Gangemi</title>
    <link rel="canonical" href={canonicalUrl} />
    <meta http-equiv="refresh" content={`0; url=${canonicalUrl}`} />
    <style>
      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        background: #05070D;
        color: #FFFFFF;
        margin: 0;
        padding: 2rem;
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
      }
      .container {
        text-align: center;
        max-width: 400px;
      }
      h1 {
        font-size: 1.5rem;
        margin-bottom: 1rem;
      }
      p {
        margin: 1rem 0;
        line-height: 1.6;
      }
      a {
        color: #F57C00;
        text-decoration: none;
        font-weight: 500;
      }
      a:hover {
        text-decoration: underline;
      }
    </style>
  </head>
  <body>
    <div class="container">
      <h1>Esta página se ha movido</h1>
      <p>Estás siendo redirigido a nuestra página de contacto.</p>
      <p><a href={destination}>Haz clic aquí si no eres redirigido automáticamente</a></p>
    </div>
  </body>
</html>
