---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  title="AI Strategy Speaker"
  description="AI Strategy and Digital Transformation speaking for executive audiences — operating models, enterprise agility, AI governance and business impact."
  noIndex={true}
>

  <section class="section-py bg-[#05070D]" aria-labelledby="speaking-heading">
    <div class="container-site">

      <nav class="mb-8" aria-label="Breadcrumb">
        <a href="/" class="text-white/40 text-sm hover:text-white/65 transition-colors">
          ← Facundo Gangemi
        </a>
      </nav>

      <span class="eyebrow">Speaking</span>

      <h1 id="speaking-heading" class="text-section font-heading font-bold text-white mt-2 mb-6 max-w-[20ch]">
        Speaking &amp; Executive Events
      </h1>

      <p class="text-white/65 text-lg leading-relaxed max-w-[56ch] mb-6">
        Speaking engagements for executive audiences, leadership teams and transformation
        conferences on AI Strategy, Digital Transformation, Enterprise Agility and
        Operating Models. Sessions are designed to be practical, evidence-based
        and directly applicable to enterprise decision-making.
      </p>

      <p class="text-white/50 leading-relaxed max-w-[56ch] mb-12">
        Topics include: AI strategy and governance for enterprise organizations, connecting
        AI investment to operating model outcomes, enterprise agility beyond frameworks,
        OKR and QBR governance at scale, and the leadership disciplines that sustain
        transformation momentum. Contact to discuss speaking availability and topics.
      </p>

      <div class="flex flex-wrap gap-4">
        <a href="/contact" class="btn-primary">
          Enquire About Speaking
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <a href="/about" class="btn-outline">About Facundo</a>
      </div>

    </div>
  </section>

</BaseLayout>
