---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allCaseStudies = await getCollection('case-studies');

const caseStudies = allCaseStudies
  .filter((cs) => cs.data.confidentiality !== 'internal')
  .sort((a, b) => a.data.order - b.data.order);

const count = caseStudies.length;

const SEO_TITLE = 'Case Studies | Digital Transformation | Facundo Gangemi';
const SEO_DESCRIPTION =
  'Selected case studies in AI strategy, digital transformation and operational excellence. Real enterprise transformation outcomes, anonymized by design.';

const HERO_IMAGE = '/images/case-studies/case-studies-hero.webp';

const CASE_GROUPS = [
  {
    label: 'Financial Services & Regulated Industries',
    slugs: ['financial-services-agile-transformation', 'insurance-process-digitization'],
  },
  {
    label: 'Enterprise Execution & Governance',
    slugs: ['operational-excellence-delivery-governance', 'strategic-alignment-okrs-qbrs-portfolio'],
  },
  {
    label: 'AI Strategy & Digital Platform',
    slugs: ['ai-ready-digital-platform-enablement', 'devops-microservices-platform-modernization'],
  },
];

const METHOD_STEPS = [
  {
    num: '01',
    phase: 'Diagnose',
    body: 'Understand the business challenge, operating constraints and execution gaps before defining any solution.',
  },
  {
    num: '02',
    phase: 'Design',
    body: 'Define the operating model, governance structure and transformation approach aligned to business priorities.',
  },
  {
    num: '03',
    phase: 'Align',
    body: 'Connect executives, teams and stakeholders around priorities, ownership and decision-making routines.',
  },
  {
    num: '04',
    phase: 'Execute',
    body: 'Support implementation through agile practices, playbooks, coaching and delivery governance.',
  },
  {
    num: '05',
    phase: 'Measure',
    body: 'Track progress through outcomes, delivery indicators and leadership visibility signals.',
  },
];
---

<BaseLayout
  title={SEO_TITLE}
  description={SEO_DESCRIPTION}
  canonical="/case-studies/"
  ogImage="/assets/og/og-case-studies.webp"
  ogImageAlt="Transformation case studies focused on strategy, execution and impact"
  preloadImage={HERO_IMAGE}
  structuredData={[{
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: 'Transformation Case Studies — Facundo Gangemi',
    description: SEO_DESCRIPTION,
    url: 'https://facundogangemi.com/case-studies/',
    author: {
      '@type': 'Person',
      name: 'Facundo Gangemi',
      url: 'https://facundogangemi.com',
    },
  }]}
>

  <!-- ── 1. Hero ──────────────────────────────────────────────────────────── -->
  <section class="section-py-lg bg-[#05070D]" aria-labelledby="cs-h1">
    <div class="container-site">
      <div class="cs-hero-layout">

        <!-- Left: editorial text -->
        <div class="cs-hero-text">
          <span class="eyebrow">Case Studies</span>

          <h1 id="cs-h1" class="cs-h1 font-heading font-bold text-white mt-2 reveal">
            Digital Transformation Case Studies in Enterprise Execution
          </h1>

          <p class="cs-hero-lead reveal delay-100">
            Selected enterprise transformation cases showing how AI readiness, governance,
            operational excellence and delivery discipline create measurable business progress.
          </p>

          <p class="cs-hero-meta reveal delay-100">
            {count} selected case studies · anonymized by design
          </p>

          <div class="cs-hero-cta reveal delay-200">
            <a href="/contact/" class="btn-primary">
              Discuss a transformation challenge
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
            <a href="/advisory/" class="btn-outline">Explore advisory services</a>
          </div>
        </div>

        <!-- Right: hero image -->
        <div class="cs-hero-visual reveal delay-200" aria-hidden="true">
          <div class="cs-hero-image-wrap">
            <img
              src={HERO_IMAGE}
              alt="Abstract executive case study visual representing transformation strategy, governance and operating model impact"
              width="760"
              height="570"
              loading="eager"
              decoding="async"
              class="cs-hero-img"
            />
            <div class="cs-hero-fade-left"></div>
            <div class="cs-hero-fade-bottom"></div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ── 2. Confidentiality Note ─────────────────────────────────────────── -->
  <section class="section-py-xs bg-gray-950" aria-label="Confidentiality notice">
    <div class="container-site">
      <div class="cs-anon-block reveal">
        <!-- ⓘ icon -->
        <svg class="cs-anon-icon" width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
          <circle cx="9" cy="9" r="7.5" stroke="rgba(245,124,0,0.62)" stroke-width="1.3"/>
          <line x1="9" y1="8" x2="9" y2="13" stroke="rgba(245,124,0,0.62)" stroke-width="1.5" stroke-linecap="round"/>
          <circle cx="9" cy="5.5" r="0.85" fill="rgba(245,124,0,0.62)"/>
        </svg>
        <p class="cs-anon-title">Anonymized by design</p>
        <p class="cs-anon-quote">
          "These case studies are intentionally anonymized to protect client confidentiality.
          They reflect real transformation patterns across strategy, governance, delivery and
          operating model evolution."
        </p>
      </div>
    </div>
  </section>

  <!-- ── 3. Case Study Cards ─────────────────────────────────────────────── -->
  <section class="section-py bg-[#05070D]" aria-labelledby="cs-grid-heading">
    <div class="container-site">

      <h2 id="cs-grid-heading" class="cs-grid-h2 font-heading font-semibold text-white reveal">Selected transformation case studies</h2>

      <div class="cs-groups">
        {CASE_GROUPS.map((group, gi) => {
          const groupCases = caseStudies.filter((cs) =>
            group.slugs.some((s) => cs.id.endsWith(`${s}.md`))
          );
          if (groupCases.length === 0) return null;
          const groupNum = String(gi + 1).padStart(2, '0');
          return (
            <div class="cs-group">
              <div class="cs-group-header reveal">
                <span class="cs-group-num font-heading" aria-hidden="true">{groupNum}</span>
                <h3 class="cs-group-label font-heading">{group.label}</h3>
                <div class="cs-group-rule" aria-hidden="true"></div>
              </div>
              <div class="cs-grid">
                {groupCases.map((cs) => (
                  <article class="cs-card reveal" aria-label={cs.data.title}>

                    <!-- Header: eyebrow · title · summary -->
                    <header class="cs-card-header">
                      <p class="cs-card-eyebrow">CASE STUDY · {cs.data.sector.toUpperCase()}</p>
                      <h3 class="cs-card-title font-heading">{cs.data.title}</h3>
                      <p class="cs-card-summary">{cs.data.summary}</p>
                    </header>

                    <!-- Strategic proof block -->
                    <div class="cs-proof-block">
                      <p class="cs-proof-label">Strategic proof</p>
                      <p class="cs-proof-text">{cs.data.strategicProof}</p>
                    </div>

                    <!-- Challenge · Intervention · Impact -->
                    <div class="cs-detail">
                      <div class="cs-detail-col">
                        <p class="cs-detail-num font-heading" aria-hidden="true">01</p>
                        <p class="cs-detail-label">Challenge</p>
                        <p class="cs-detail-text">{cs.data.challenge}</p>
                      </div>
                      <div class="cs-detail-col">
                        <p class="cs-detail-num font-heading" aria-hidden="true">02</p>
                        <p class="cs-detail-label">Intervention</p>
                        <p class="cs-detail-text">{cs.data.intervention}</p>
                      </div>
                      <div class="cs-detail-col">
                        <p class="cs-detail-num font-heading" aria-hidden="true">03</p>
                        <p class="cs-detail-label">Impact</p>
                        <p class="cs-detail-text">{cs.data.impact}</p>
                      </div>
                    </div>

                    <!-- Footer: tags · CTA -->
                    <footer class="cs-card-footer">
                      <ul class="cs-tags" aria-label="Topics" role="list">
                        {cs.data.tags.map((tag) => (
                          <li class="cs-tag">{tag}</li>
                        ))}
                      </ul>
                      <a href={cs.data.ctaHref} class="cs-cta-link">
                        {cs.data.ctaLabel}
                        <svg class="cs-cta-arrow" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                          <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                      </a>
                    </footer>

                  </article>
                ))}
              </div>
            </div>
          );
        })}
      </div>

    </div>
  </section>

  <!-- ── 4. Advisory Method ──────────────────────────────────────────────── -->
  <section class="section-py bg-gray-950" aria-labelledby="cs-method-heading">
    <div class="container-site">

      <div class="cs-method-intro reveal">
        <span class="eyebrow">Advisory Method</span>
        <h2 id="cs-method-heading" class="cs-method-h2 font-heading font-semibold text-white mt-1">
          How transformation work becomes measurable impact
        </h2>
        <p class="cs-method-lead">
          Each case follows the same advisory logic, grounded in <a href="/about/" class="cs-inline-link">Facundo's advisory background</a>: understand the business challenge,
          design the right operating model, align stakeholders, support execution and
          measure progress through business-relevant signals.
        </p>
      </div>

      <div class="cs-method-steps">
        {METHOD_STEPS.map((step, i) => (
          <div class={`cs-method-step reveal${i > 0 ? ` delay-${Math.min(i, 3) * 100}` : ''}`}>
            <div class="cs-method-num font-heading" aria-hidden="true">{step.num}</div>
            <p class="cs-method-phase">{step.phase}</p>
            <p class="cs-method-body">{step.body}</p>
          </div>
        ))}
      </div>

    </div>
  </section>

  <!-- ── 5. Final CTA ────────────────────────────────────────────────────── -->
  <section class="section-py bg-[#05070D]" aria-labelledby="cs-final-heading">
    <div class="container-site">
      <div class="cs-final-card reveal">
        <div class="cs-final-inner">
          <span class="eyebrow">Strategic Advisory</span>
          <h2 id="cs-final-heading" class="cs-final-h2 font-heading font-bold text-white">
            Facing a similar transformation challenge?
          </h2>
          <p class="cs-final-body">
            These cases reflect real enterprise transformation contexts. Explore <a href="/insights/" class="cs-inline-link">strategic insights</a> or discuss your
            specific challenge to explore whether there is a relevant advisory approach.
          </p>
          <div class="cs-final-actions">
            <a href="/contact/" class="btn-primary">
              Book Advisory Call
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
            <a href="/advisory/" class="btn-outline">Explore Advisory Services</a>
          </div>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ── Hero layout ─────────────────────────────────────────────────────────── */

  .cs-hero-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: center;
  }

  @media (min-width: 1024px) {
    .cs-hero-layout {
      grid-template-columns: 55fr 45fr;
      gap: 4.5rem;
    }
  }

  .cs-hero-text {
    display: flex;
    flex-direction: column;
  }

  /* Hero image */

  .cs-hero-visual {
    display: block;
  }

  @media (max-width: 1023px) {
    .cs-hero-visual { display: none; }
  }

  .cs-hero-image-wrap {
    position: relative;
    border-radius: 1.25rem;
    overflow: hidden;
    aspect-ratio: 4 / 3;
    border: 1px solid rgba(255, 255, 255, 0.07);
  }

  .cs-hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    filter: brightness(0.80);
  }

  .cs-hero-fade-left {
    position: absolute;
    inset-y: 0;
    left: 0;
    width: 20%;
    background: linear-gradient(to right, #05070D, transparent);
    pointer-events: none;
  }

  .cs-hero-fade-bottom {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 22%;
    background: linear-gradient(to top, #05070D, transparent);
    pointer-events: none;
  }

  /* Hero typography */

  .cs-h1 {
    font-size: clamp(2rem, 4.5vw, 3.25rem);
    line-height: 1.12;
    letter-spacing: -0.025em;
    max-width: 20ch;
    margin: 0.75rem 0 1.5rem;
  }

  .cs-hero-lead {
    font-size: 1.0625rem;
    color: rgba(255, 255, 255, 0.65);
    line-height: 1.70;
    max-width: 54ch;
    margin: 0 0 0.875rem;
  }

  .cs-hero-meta {
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    color: rgba(255, 255, 255, 0.28);
    margin: 0 0 2rem;
  }

  .cs-hero-cta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.875rem;
    align-items: center;
  }

  /* ── Confidentiality note ────────────────────────────────────────────────── */

  .cs-anon-block {
    max-width: 740px;
    margin: 0 auto;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.625rem;
  }

  .cs-anon-icon {
    display: block;
    flex-shrink: 0;
    margin-bottom: 0.125rem;
  }

  .cs-anon-title {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(245, 124, 0, 0.78);
    margin: 0;
  }

  .cs-anon-quote {
    font-size: 0.9375rem;
    font-style: italic;
    color: rgba(255, 255, 255, 0.48);
    line-height: 1.70;
    margin: 0;
    max-width: 62ch;
  }

  /* ── Case Card Grid ──────────────────────────────────────────────────────── */

  .cs-grid {
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
  }

  .cs-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 1.375rem;
    padding: 1.75rem 2rem;
    border-radius: var(--radius-card);
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.02);
    transition: border-color 240ms ease, box-shadow 240ms ease, transform 240ms ease;
  }

  /* Dossier stack: two pseudo-element layers sit behind each card */

  .cs-card::before,
  .cs-card::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: var(--radius-card);
    pointer-events: none;
  }

  .cs-card::before {
    z-index: -1;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.018);
    transform: translate(7px, 7px);
    transition: transform 240ms ease, border-color 240ms ease;
  }

  .cs-card::after {
    z-index: -2;
    border: 1px solid rgba(255, 255, 255, 0.05);
    background: rgba(255, 255, 255, 0.008);
    transform: translate(13px, 13px);
    transition: transform 240ms ease;
  }

  .cs-card:hover {
    border-color: rgba(245, 124, 0, 0.24);
    box-shadow: 0 0 0 1px rgba(245, 124, 0, 0.06) inset,
                0 16px 56px rgba(0, 0, 0, 0.36);
    transform: translateY(-2px);
  }

  .cs-card:hover::before {
    transform: translate(10px, 10px);
    border-color: rgba(245, 124, 0, 0.15);
  }

  .cs-card:hover::after {
    transform: translate(17px, 17px);
  }

  /* Mobile: vertical offset only — prevents horizontal overflow on narrow viewports */
  @media (max-width: 767px) {
    .cs-card::before { transform: translate(0, 6px); }
    .cs-card::after  { transform: translate(0, 10px); }
    .cs-card:hover::before { transform: translate(0, 8px); }
    .cs-card:hover::after  { transform: translate(0, 13px); }
  }

  @media (max-width: 639px) {
    .cs-card { padding: 1.25rem 1rem; gap: 1.125rem; }
  }

  /* Card header */

  .cs-card-header {
    padding-bottom: 1.25rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .cs-card-eyebrow {
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(245, 124, 0, 0.80);
    margin: 0 0 0.75rem;
  }

  .cs-card-title {
    font-size: clamp(1.2rem, 2.2vw, 1.5rem);
    font-weight: 700;
    color: #ffffff;
    line-height: 1.22;
    letter-spacing: -0.015em;
    margin: 0 0 0.75rem;
  }

  .cs-card-summary {
    font-size: 0.9375rem;
    color: rgba(255, 255, 255, 0.68);
    line-height: 1.70;
    margin: 0;
    max-width: 76ch;
  }

  /* Strategic proof */

  .cs-proof-block {
    padding: 0.875rem 1.125rem;
    border-left: 3px solid rgba(245, 124, 0, 0.50);
    border-radius: 0 0.5rem 0.5rem 0;
    background: rgba(245, 124, 0, 0.04);
  }

  .cs-proof-label {
    font-size: 0.625rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(245, 124, 0, 0.65);
    margin: 0 0 0.4rem;
  }

  .cs-proof-text {
    font-size: 0.875rem;
    font-style: italic;
    color: rgba(255, 255, 255, 0.65);
    line-height: 1.65;
    margin: 0;
  }

  /* Challenge · Intervention · Impact */

  .cs-detail {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  @media (min-width: 768px) {
    .cs-detail {
      grid-template-columns: repeat(3, 1fr);
      gap: 2rem;
    }
  }

  .cs-detail-col {
    display: flex;
    flex-direction: column;
  }

  .cs-detail-num {
    font-size: 1.625rem;
    font-weight: 800;
    line-height: 1;
    letter-spacing: -0.02em;
    color: rgba(245, 124, 0, 0.50);
    margin: 0 0 0.4rem;
  }

  .cs-detail-label {
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.62);
    margin: 0 0 0.4rem;
  }

  .cs-detail-text {
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.72);
    line-height: 1.68;
    margin: 0;
  }

  /* Footer: tags + CTA */

  .cs-card-footer {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.875rem;
  }

  .cs-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .cs-tag {
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    padding: 0.25rem 0.7rem;
    border-radius: 2rem;
    border: 1px solid rgba(255, 255, 255, 0.12);
    color: rgba(255, 255, 255, 0.48);
    background: rgba(255, 255, 255, 0.04);
    white-space: nowrap;
  }

  .cs-cta-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.82rem;
    font-weight: 700;
    color: rgba(245, 124, 0, 0.80);
    text-decoration: none;
    white-space: nowrap;
    flex-shrink: 0;
    transition: color 180ms ease;
  }

  .cs-cta-link:hover {
    color: #F57C00;
  }

  .cs-cta-arrow {
    transition: transform 180ms ease;
  }

  .cs-cta-link:hover .cs-cta-arrow {
    transform: translateX(3px);
  }

  /* ── Advisory Method ─────────────────────────────────────────────────────── */

  .cs-method-intro {
    max-width: 640px;
    margin-bottom: 3rem;
  }

  .cs-method-h2 {
    font-size: clamp(1.5rem, 3vw, 2.125rem);
    line-height: 1.22;
    letter-spacing: -0.015em;
    margin: 0.75rem 0 1.25rem;
  }

  .cs-method-lead {
    font-size: 0.9375rem;
    color: rgba(255, 255, 255, 0.50);
    line-height: 1.70;
    margin: 0;
  }

  .cs-method-steps {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  @media (min-width: 640px) {
    .cs-method-steps {
      grid-template-columns: 1fr 1fr;
      gap: 2.5rem 2rem;
    }
  }

  @media (min-width: 1024px) {
    .cs-method-steps {
      grid-template-columns: repeat(5, 1fr);
      gap: 2rem;
    }
  }

  .cs-method-step {
    display: flex;
    flex-direction: column;
  }

  .cs-method-num {
    font-size: 2.5rem;
    font-weight: 800;
    line-height: 1;
    letter-spacing: -0.02em;
    color: rgba(245, 124, 0, 0.55);
    margin-bottom: 0.625rem;
  }

  .cs-method-phase {
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.70);
    margin: 0 0 0.5rem;
  }

  .cs-method-body {
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.50);
    line-height: 1.68;
    margin: 0;
  }

  /* ── Final CTA ───────────────────────────────────────────────────────────── */

  .cs-final-card {
    border-radius: 1.25rem;
    padding: 3.5rem 2.5rem;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.07);
    border-top: 2px solid rgba(245, 124, 0, 0.40);
  }

  @media (min-width: 1024px) {
    .cs-final-card { padding: 5rem 4rem; }
  }

  .cs-final-inner {
    max-width: 720px;
    margin: 0 auto;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .cs-final-h2 {
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    line-height: 1.18;
    letter-spacing: -0.02em;
    margin: 0.75rem 0 1.25rem;
  }

  .cs-final-body {
    font-size: 1rem;
    color: rgba(255, 255, 255, 0.56);
    line-height: 1.72;
    max-width: 52ch;
    margin: 0 0 2.25rem;
  }

  .cs-final-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.875rem;
    justify-content: center;
  }

  /* ── Case grid heading ───────────────────────────────────────────────────── */

  .cs-grid-h2 {
    font-size: clamp(1.5rem, 3vw, 2.125rem);
    line-height: 1.22;
    letter-spacing: -0.015em;
