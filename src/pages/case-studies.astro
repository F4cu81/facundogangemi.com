---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  title="Transformation Case Studies"
  description="Transformation experiences in AI strategy, digital transformation, enterprise agility and operating model redesign across banking and financial services."
  noIndex={true}
>

  <section class="section-py bg-[#05070D]" aria-labelledby="case-studies-heading">
    <div class="container-site">

      <nav class="mb-8" aria-label="Breadcrumb">
        <a href="/" class="text-white/40 text-sm hover:text-white/65 transition-colors">
          ← Facundo Gangemi
        </a>
      </nav>

      <span class="eyebrow">Case Studies</span>

      <h1 id="case-studies-heading" class="text-section font-heading font-bold text-white mt-2 mb-6 max-w-[20ch]">
        Transformation Case Studies
      </h1>

      <p class="text-white/65 text-lg leading-relaxed max-w-[56ch] mb-6">
        Selected transformation experiences across banking and financial services,
        technology and product organizations — covering AI strategy implementation,
        digital operating model design, enterprise agility programs and execution
        governance at scale.
      </p>

      <p class="text-white/50 leading-relaxed max-w-[56ch] mb-12">
        Detailed case studies are being prepared for publication here. They will document
        transformation patterns, operating model decisions and measurable outcomes across
        real enterprise contexts — without disclosing confidential client information.
        Contact to discuss specific transformation challenges in the meantime.
      </p>

      <div class="flex flex-wrap gap-4">
        <a href="/contact" class="btn-primary">
          Discuss Your Transformation
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <a href="/advisory" class="btn-outline">Explore Advisory Services</a>
      </div>

    </div>
  </section>

</BaseLayout>
