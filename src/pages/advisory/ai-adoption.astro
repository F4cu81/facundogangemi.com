---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  title="AI Adoption Strategy"
  description="AI Adoption Strategy Advisory. Guide your organization from AI awareness through use-case prioritization to embedded, scalable AI practices and governance."
>

  <section class="section-py bg-[#05070D]" aria-labelledby="ai-adoption-heading">
    <div class="container-site">

      <nav class="mb-8" aria-label="Breadcrumb">
        <a href="/advisory" class="text-white/40 text-sm hover:text-white/65 transition-colors">
          ← Advisory
        </a>
      </nav>

      <span class="eyebrow">Advisory · AI Adoption</span>

      <h1 id="ai-adoption-heading" class="text-section font-heading font-bold text-white mt-2 mb-6 max-w-[20ch]">
        AI Adoption Strategy Advisory
      </h1>

      <p class="text-white/65 text-lg leading-relaxed max-w-[56ch] mb-6">
        AI adoption requires more than deploying tools. It requires readiness assessment,
        structured use-case prioritization, capability building and a governance model that
        scales. I guide enterprise organizations through the full adoption journey — from
        AI awareness to embedded, operationally integrated AI practices.
      </p>

      <p class="text-white/50 leading-relaxed max-w-[56ch] mb-12">
        The advisory covers AI readiness evaluation, use-case selection frameworks,
        adoption roadmaps, change management for AI-enabled teams, and the governance
        structures that keep AI adoption responsible and strategically aligned. Applicable
        across banking, financial services and technology-driven organizations.
      </p>

      <div class="flex flex-wrap gap-4">
        <a href="/contact" class="btn-primary">
          Book Advisory Call
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <a href="/ai-assessment" class="btn-outline">Explore AI Assessment</a>
      </div>

    </div>
  </section>

</BaseLayout>
