---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  title="Enterprise Agility Advisory"
  description="Enterprise Agility Advisory. Build adaptive operating models, strengthen OKR and QBR governance and improve execution discipline at enterprise scale."
  noIndex={true}
>

  <section class="section-py bg-[#05070D]" aria-labelledby="ea-heading">
    <div class="container-site">

      <nav class="mb-8" aria-label="Breadcrumb">
        <a href="/advisory" class="text-white/40 text-sm hover:text-white/65 transition-colors">
          ← Advisory
        </a>
      </nav>

      <span class="eyebrow">Advisory · Enterprise Agility</span>

      <h1 id="ea-heading" class="text-section font-heading font-bold text-white mt-2 mb-6 max-w-[20ch]">
        Enterprise Agility Advisory
      </h1>

      <p class="text-white/65 text-lg leading-relaxed max-w-[56ch] mb-6">
        Enterprise agility is an operating model property — not a methodology or a set of
        ceremonies. I help organizations evolve how they decide, organize and deliver at scale,
        moving beyond framework adoption toward genuine organizational adaptability and
        execution discipline.
      </p>

      <p class="text-white/50 leading-relaxed max-w-[56ch] mb-12">
        The advisory covers OKR design and implementation, QBR governance, portfolio management,
        delivery discipline and the structural changes that enable organizations to respond
        to strategic change without losing execution momentum. Applied in complex, regulated
        and multi-team enterprise environments.
      </p>

      <div class="flex flex-wrap gap-4">
        <a href="/contact" class="btn-primary">
          Book Advisory Call
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <a href="/advisory" class="btn-outline">All Advisory Services</a>
      </div>

    </div>
  </section>

</BaseLayout>
