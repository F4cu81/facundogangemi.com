<script>
  /* Map marker ↔ country chip interaction */
  const markers = document.querySelectorAll('.map-marker');

  function setChipActive(country: string, active: boolean) {
    const chip = document.querySelector<HTMLElement>(`.country-chip[data-country="${country}"]`);
    if (chip) chip.classList.toggle('active', active);
  }

  markers.forEach((marker) => {
    const country = (marker as HTMLElement).dataset.country ?? '';
    marker.addEventListener('mouseenter', () => setChipActive(country, true));
    marker.addEventListener('mouseleave', () => setChipActive(country, false));
    marker.addEventListener('focus',      () => setChipActive(country, true));
    marker.addEventListener('blur',       () => setChipActive(country, false));
  });
</script>
