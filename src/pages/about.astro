---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  title="About Facundo Gangemi"
  description="AI Strategy and Digital Transformation Advisor. Enterprise experience across banking, financial services, technology and operating model transformation."
>

  <section class="section-py bg-[#05070D]" aria-labelledby="about-heading">
    <div class="container-site">

      <nav class="mb-8" aria-label="Breadcrumb">
        <a href="/" class="text-white/40 text-sm hover:text-white/65 transition-colors">
          ← Facundo Gangemi
        </a>
      </nav>

      <span class="eyebrow">About</span>

      <h1 id="about-heading" class="text-section font-heading font-bold text-white mt-2 mb-6 max-w-[28ch]">
        Facundo Gangemi — AI Strategy &amp; Digital Transformation Advisor
      </h1>

      <p class="text-white/65 text-lg leading-relaxed max-w-[56ch] mb-6">
        AI Strategy and Digital Transformation Advisor working with enterprise leaders
        on the intersection of technology strategy, operating model evolution and
        execution discipline. The advisory practice spans AI Strategy, Digital
        Transformation, Enterprise Agility and AI Adoption.
      </p>

      <p class="text-white/50 leading-relaxed max-w-[56ch] mb-6">
        With over 20 years of professional experience across banking, financial services,
        technology and product organizations, the work combines strategic advisory with
        practical execution — from AI governance frameworks and transformation roadmaps
        to OKR implementation, QBR governance and portfolio management at enterprise scale.
      </p>

      <p class="text-white/50 leading-relaxed max-w-[56ch] mb-12">
        Based in Barcelona. Working with organizations across Europe and Latin America.
      </p>

      <div class="flex flex-wrap gap-4">
        <a href="/contact" class="btn-primary">
          Book Advisory Call
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <a href="/advisory" class="btn-outline">Explore Advisory Services</a>
      </div>

    </div>
  </section>

</BaseLayout>
