---
import { INSIGHT_PILLARS } from '@/data/insightPillars';

/*
 * Topic-aligned icons — inline SVG strings, rendered with set:html.
 * All icons: 30×30 viewport, stroke-only, currentColor (inherits .sp-icon color).
 * aria-hidden is set on the container div, not here.
 */
const ICONS: string[] = [
  // 01 — AI Strategy: neural hub — 3 satellite nodes + center hub + connecting lines
  `<svg width="30" height="30" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
    <circle cx="14" cy="4"  r="2.2" stroke="currentColor" stroke-width="1.4"/>
    <circle cx="23" cy="20" r="2.2" stroke="currentColor" stroke-width="1.4"/>
    <circle cx="5"  cy="20" r="2.2" stroke="currentColor" stroke-width="1.4"/>
    <circle cx="14" cy="14" r="2.5" stroke="currentColor" stroke-width="1.4"/>
    <line x1="14"  y1="6.3"  x2="14"  y2="11.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
    <line x1="21.2" y1="18.5" x2="16.2" y2="15.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
    <line x1="6.8"  y1="18.5" x2="11.8" y2="15.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
  </svg>`,

  // 02 — Digital Transformation: stacked diamond layers — top solid layer + two open chevron rows
  `<svg width="30" height="30" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
    <path d="M14 3L25 9L14 15L3 9Z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/>
    <path d="M3 14l11 6 11-6"       stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
    <path d="M3 19l11 6 11-6"       stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
  </svg>`,

  // 03 — Operational Excellence: gauge — upper semicircle arc, three tick marks, performance needle
  `<svg width="30" height="30" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
    <path d="M3 22 A11 11 0 0 1 25 22" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    <line x1="3"  y1="22"   x2="4.5"  y2="20.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
    <line x1="14" y1="11"   x2="14"   y2="13"   stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
    <line x1="25" y1="22"   x2="23.5" y2="20.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
    <line x1="14" y1="22"   x2="20.5" y2="14"   stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
    <circle cx="14" cy="22" r="2" stroke="currentColor" stroke-width="1.3"/>
  </svg>`,

  // 04 — AI Adoption: adoption S-curve with milestone nodes — awareness → acceleration → embedded
  `<svg width="30" height="30" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
    <path d="M3 24C7 24 8 19 14 14C20 9 21 5 25 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    <circle cx="5"  cy="23" r="1.8" stroke="currentColor" stroke-width="1.2"/>
    <circle cx="14" cy="14" r="1.8" stroke="currentColor" stroke-width="1.2"/>
    <circle cx="23" cy="5"  r="1.8" stroke="currentColor" stroke-width="1.2"/>
  </svg>`,
];
---

<section
  class="sp-section section-py"
  aria-labelledby="strategic-perspectives-heading"
>
  <!-- Background image — purely decorative atmospheric texture, aria-hidden -->
  <div class="sp-bg" aria-hidden="true">
    <img
      src="/images/insights/insights-abstract-bg.webp"
      alt=""
      class="sp-bg-img"
      loading="lazy"
      decoding="async"
    />
    <!--
      Horizontal gradient:
        left  → fully opaque #05070D  (intro column stays clean)
        right → 42% dark             (allows more image atmosphere behind cards)
    -->
    <div class="sp-bg-overlay"></div>
  </div>

  <div class="container-site sp-layout">

    <!-- Left column: section intro -->
    <div class="sp-intro reveal">
      <span class="eyebrow">Insights</span>
      <h2
        id="strategic-perspectives-heading"
        class="text-section font-heading font-semibold text-white mt-2 mb-5"
      >
        Strategic<br class="hidden lg:block" />Perspectives
      </h2>
      <p class="sp-subtitle">
        Explore selected themes on AI strategy, digital transformation,
        operational excellence and AI adoption.
      </p>
      <p class="sp-supporting">
        Selected perspectives designed to connect strategy, operating models,
        adoption and measurable business impact.
      </p>
      <a href="/insights/" class="sp-view-all">
        View all insights
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true" class="sp-view-arrow">
          <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>

    <!-- Right column: 2×2 card grid -->
    <div class="sp-cards">
      {INSIGHT_PILLARS.map((pillar, i) => (
        <a
          href={pillar.href}
          class={`sp-card reveal delay-${i * 100}`}
          aria-label={`${pillar.cta} — insights and perspectives`}
        >
          <!-- Card header: icon top-right -->
          <div class="sp-card-header">
            <div class="sp-icon" aria-hidden="true" set:html={ICONS[i]} />
          </div>

          <h3 class="sp-card-title">{pillar.title}</h3>
          <p class="sp-card-desc">{pillar.description}</p>

          <span class="sp-cta">
            {pillar.cta}
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true" class="sp-arrow">
              <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
        </a>
      ))}
    </div>

  </div>
</section>

<style>
  /* ── Section shell ──────────────────────────────────────────────────────── */
  .sp-section {
    position: relative;
    overflow: hidden;
    background: #05070D;
  }

  /* ── Background image layer ─────────────────────────────────────────────── */
  .sp-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    user-select: none;
  }

  .sp-bg-img {
    position: absolute;
    top: -8%;
    left: 0;
    width: 100%;
    height: 115%;
    object-fit: cover;
    /* crop anchor on the open-book detail (lower-right quadrant of source image) */
    object-position: 78% 72%;
    opacity: 0.60;
    /* desaturate blue channel instead of hiding the image — preserves texture, removes cast */
    filter: saturate(0.40) brightness(0.82) contrast(1.10);
  }

  .sp-bg-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      90deg,
      #05070D 0%,
      rgba(5, 7, 13, 0.97) 35%,
      rgba(5, 7, 13, 0.68) 62%,
      rgba(5, 7, 13, 0.34) 100%
    );
  }

  /* ── Two-column editorial layout ────────────────────────────────────────── */
  .sp-layout {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: start;
  }

  @media (min-width: 1024px) {
    .sp-layout {
      grid-template-columns: 34fr 66fr;
      gap: 5rem;
    }
  }

  /* ── Left: intro copy ───────────────────────────────────────────────────── */
  .sp-subtitle {
    color: rgba(255, 255, 255, 0.60);
    font-size: 1rem;
    line-height: 1.7;
    margin: 0 0 0.85rem;
    max-width: 40ch;
  }

  .sp-supporting {
    color: rgba(255, 255, 255, 0.36);
    font-size: 0.875rem;
    line-height: 1.65;
    margin: 0 0 2rem;
    max-width: 38ch;
  }

  .sp-view-all {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.875rem;
    font-weight: 700;
    color: rgba(245, 124, 0, 0.80);
    text-decoration: none;
    transition: color 180ms ease, gap 180ms ease;
  }

  .sp-view-all:hover {
    color: #F57C00;
    gap: 0.6rem;
  }

  .sp-view-arrow {
    flex-shrink: 0;
    transition: transform 180ms ease;
  }

  .sp-view-all:hover .sp-view-arrow {
    transform: translateX(3px);
  }

  /* ── Right: 2×2 card grid ───────────────────────────────────────────────── */
  .sp-cards {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  @media (min-width: 560px) {
    .sp-cards {
      grid-template-columns: 1fr 1fr;
    }
  }

  /* ── Cards ──────────────────────────────────────────────────────────────── */
  .sp-card {
    display: flex;
    flex-direction: column;
    padding: 1.625rem;
    border-radius: 1rem;
    border: 1px solid rgba(245, 124, 0, 0.18);
    border-top: 2px solid rgba(245, 124, 0, 0.42);
    background: rgba(5, 7, 13, 0.55);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    text-decoration: none;
    transition:
      background 240ms ease,
      border-color 240ms ease,
      border-top-color 240ms ease,
      transform 240ms ease,
      box-shadow 240ms ease;
  }

  .sp-card:hover {
    background: rgba(5, 7, 13, 0.72);
    border-color: rgba(245, 124, 0, 0.32);
    border-top-color: rgba(245, 124, 0, 0.85);
    transform: translateY(-3px);
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.55);
  }

  /* ── Card header row ────────────────────────────────────────────────────── */
  .sp-card-header {
    display: flex;
    align-items: flex-start;
    justify-content: flex-end;
    margin-bottom: 1rem;
  }

  /* Icon container — color inherited by SVG currentColor strokes */
  .sp-icon {
    color: rgba(245, 124, 0, 0.70);
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color 240ms ease;
  }

  .sp-card:hover .sp-icon {
    color: rgba(245, 124, 0, 0.90);
  }

  /* ── Card body ──────────────────────────────────────────────────────────── */
  .sp-card-title {
    font-family: Manrope, system-ui, sans-serif;
    font-size: 1.05rem;
    font-weight: 700;
    color: #ffffff;
    line-height: 1.2;
    margin: 0 0 0.65rem;
  }

  .sp-card-desc {
    font-size: 0.83rem;
    color: rgba(255, 255, 255, 0.50);
    line-height: 1.65;
    margin: 0 0 auto;
    padding-bottom: 1.25rem;
  }

  .sp-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.80rem;
    font-weight: 700;
    color: rgba(245, 124, 0, 0.70);
    transition: color 180ms ease, gap 180ms ease;
  }

  .sp-card:hover .sp-cta {
    color: #F57C00;
    gap: 0.6rem;
  }

  .sp-arrow {
    flex-shrink: 0;
    transition: transform 180ms ease;
  }

  .sp-card:hover .sp-arrow {
    transform: translateX(3px);
  }
</style>
