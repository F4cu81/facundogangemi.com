---
/**
 * MobileMenu — stable corrective version
 *
 * Purpose:
 * - Hidden by default.
 * - Opens only from Navbar hamburger.
 * - Avoids Tailwind @apply and fragile scoped utility behavior.
 */

import { NAV_ITEMS, NAV_CTA } from '@/data/navigation';

interface Props {
  locale?: 'en' | 'es';
  currentPath?: string;
}

const { locale = 'en', currentPath = '/' } = Astro.props;
---

<div id="mobile-menu" class="mobile-menu" aria-hidden="true">
  <div class="mobile-menu-backdrop" data-mobile-close></div>

  <aside class="mobile-menu-panel" role="dialog" aria-modal="true" aria-label="Mobile navigation">
    <div class="mobile-menu-header">
      <a href="/" class="mobile-menu-logo" data-mobile-link>Facundo</a>
      <button id="mobile-menu-close" class="mobile-menu-close" type="button" aria-label="Close mobile menu">
        ×
      </button>
    </div>

    <nav class="mobile-menu-nav" aria-label="Mobile primary navigation">
      <ul class="mobile-menu-list">
        {NAV_ITEMS.map((item) => (
          <li class="mobile-menu-item">
            {item.hasDropdown && item.children ? (
              <>
                <button
                  class={`mobile-menu-link mobile-menu-button ${currentPath === item.href ? 'active' : ''}`}
                  type="button"
                  data-mobile-dropdown-toggle={item.href}
                  aria-expanded="false"
                >
                  <span>{item.label}</span>
                  <span aria-hidden="true">▾</span>
                </button>

                <ul class="mobile-menu-dropdown" data-mobile-dropdown={item.href}>
                  {item.children.map((child) => (
                    <li>
                      <a
                        href={child.href}
                        class={`mobile-menu-sublink ${currentPath === child.href ? 'active' : ''}`}
                        data-mobile-link
                      >
                        {child.label}
                      </a>
                    </li>
                  ))}
                </ul>
              </>
            ) : (
              <a
                href={item.href}
                class={`mobile-menu-link ${currentPath === item.href ? 'active' : ''}`}
                data-mobile-link
              >
                {item.label}
              </a>
            )}
          </li>
        ))}
      </ul>

      <div class="mobile-menu-meta">
        <div class="mobile-menu-lang">
          <span class={locale === 'en' ? 'active' : ''}>EN</span>
          <span>/</span>
          <span class={locale === 'es' ? 'active' : ''}>ES <small>Soon</small></span>
        </div>

        <a href={NAV_CTA.href} class="mobile-menu-cta" data-mobile-link>
          {NAV_CTA.label}
        </a>
      </div>
    </nav>
  </aside>
</div>

<style>
  .mobile-menu {
    position: fixed;
    inset: 0;
    z-index: 200;
    display: none;
  }

  .mobile-menu.open {
    display: block;
  }

  .mobile-menu-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 14, 29, 0.72);
    backdrop-filter: blur(8px);
  }

  .mobile-menu-panel {
    position: absolute;
    top: 0;
    right: 0;
    width: min(88vw, 380px);
    height: 100%;
    padding: 1.25rem;
    background: #00274C;
    color: #ffffff;
    box-shadow: -20px 0 60px rgba(0, 0, 0, 0.3);
    overflow-y: auto;
  }

  .mobile-menu-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 2rem;
  }

  .mobile-menu-logo {
    color: #ffffff;
    font-family: Manrope, Inter, system-ui, sans-serif;
    font-size: 1.15rem;
    font-weight: 800;
    text-decoration: none;
  }

  .mobile-menu-close {
    width: 40px;
    height: 40px;
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 999px;
    background: transparent;
    color: #ffffff;
    font-size: 1.5rem;
    line-height: 1;
    cursor: pointer;
  }

  .mobile-menu-list {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .mobile-menu-link {
    display: flex;
    width: 100%;
    align-items: center;
    justify-content: space-between;
    padding: 0.9rem 0.75rem;
    color: rgba(255, 255, 255, 0.88);
    background: transparent;
    border: 0;
    border-radius: 0.75rem;
    font-family: Inter, system-ui, sans-serif;
    font-size: 1rem;
    font-weight: 650;
    text-align: left;
    text-decoration: none;
    cursor: pointer;
  }

  .mobile-menu-link:hover,
  .mobile-menu-link.active {
    color: #F57C00;
    background: rgba(255, 255, 255, 0.06);
  }

  .mobile-menu-dropdown {
    display: none;
    padding: 0.25rem 0 0.4rem 0.75rem;
    margin: 0;
    list-style: none;
  }

  .mobile-menu-dropdown.open {
    display: block;
  }

  .mobile-menu-sublink {
    display: block;
    padding: 0.7rem 0.75rem;
    color: rgba(255, 255, 255, 0.68);
    font-size: 0.94rem;
    text-decoration: none;
    border-radius: 0.65rem;
  }

  .mobile-menu-sublink:hover,
  .mobile-menu-sublink.active {
    color: #F57C00;
    background: rgba(255, 255, 255, 0.05);
  }

  .mobile-menu-meta {
    display: grid;
    gap: 1rem;
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .mobile-menu-lang {
    color: rgba(255, 255, 255, 0.66);
    font-size: 0.86rem;
  }

  .mobile-menu-lang .active {
    color: #ffffff;
    font-weight: 800;
  }

  .mobile-menu-lang small {
    opacity: 0.6;
  }

  .mobile-menu-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 0 1.2rem;
    color: #ffffff;
    background: #F57C00;
    border-radius: 999px;
    font-family: Manrope, Inter, system-ui, sans-serif;
    font-weight: 800;
    text-decoration: none;
  }

  @media (min-width: 768px) {
    .mobile-menu {
      display: none !important;
    }
  }
</style>

<script>
  const mobileMenu = document.getElementById('mobile-menu');
  const mobileMenuToggle = document.getElementById('mobile-menu-toggle');
  const mobileMenuClose = document.getElementById('mobile-menu-close');

 function setMobileMenu(open: boolean) {
    mobileMenu?.classList.toggle('open', open);
    mobileMenu?.setAttribute('aria-hidden', String(!open));
    mobileMenuToggle?.setAttribute('aria-expanded', String(open));
    document.body.style.overflow = open ? 'hidden' : '';
  }

  mobileMenuClose?.addEventListener('click', () => setMobileMenu(false));

  document.querySelectorAll('[data-mobile-close], [data-mobile-link]').forEach((element) => {
    element.addEventListener('click', () => setMobileMenu(false));
  });

  document.querySelectorAll('[data-mobile-dropdown-toggle]').forEach((button) => {
    button.addEventListener('click', () => {
      const key = button.getAttribute('data-mobile-dropdown-toggle');
      const dropdown = document.querySelector(`[data-mobile-dropdown="${key}"]`);
      const isOpen = dropdown?.classList.contains('open') ?? false;

      dropdown?.classList.toggle('open', !isOpen);
      button.setAttribute('aria-expanded', String(!isOpen));
    });
  });

  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') setMobileMenu(false);
  });

window.addEventListener('toggle-mobile-menu', (event: Event) => {
  const customEvent = event as CustomEvent<{ open?: boolean }>;
  setMobileMenu(Boolean(customEvent.detail?.open));
});
</script>
