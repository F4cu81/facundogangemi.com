---
// No props — self-contained floating button that appears after scroll.
---

<button
  id="back-to-top"
  class="btt-btn"
  type="button"
  aria-label="Back to top"
>
  <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
    <path d="M9 14V4M4 9l5-5 5 5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
  </svg>
</button>

<style>
  .btt-btn {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    z-index: 90;

    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;

    background: rgba(5, 7, 13, 0.88);
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: 999px;
    color: rgba(255, 255, 255, 0.70);
    cursor: pointer;

    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.40);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);

    opacity: 0;
    pointer-events: none;
    transform: translateY(8px);
    transition:
      opacity 240ms ease,
      transform 240ms ease,
      background 180ms ease,
      border-color 180ms ease,
      color 180ms ease,
      box-shadow 180ms ease;
  }

  .btt-btn.visible {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }

  .btt-btn:hover {
    background: rgba(5, 7, 13, 0.97);
    border-color: rgba(245, 124, 0, 0.55);
    color: #F57C00;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.55), 0 0 0 1px rgba(245, 124, 0, 0.15);
  }

  .btt-btn:focus-visible {
    outline: 2px solid #F57C00;
    outline-offset: 3px;
  }

  @media (max-width: 639px) {
    .btt-btn {
      bottom: 1.25rem;
      right: 1.25rem;
      width: 40px;
      height: 40px;
    }
  }
</style>

<script>
  (function () {
    const btn = document.getElementById('back-to-top');
    if (!btn) return;

    const SHOW_THRESHOLD = 400;

    const onScroll = () => {
      btn.classList.toggle('visible', window.scrollY > SHOW_THRESHOLD);
    };

    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll(); // initialise state without waiting for first scroll

    btn.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  })();
</script>
