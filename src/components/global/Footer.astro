---
/**
 * Footer — Global footer with 4-column layout
 * 
 * Columns:
 * 1. Advisory — AI Strategy, Digital Transformation, etc.
 * 2. Resources — Insights, Case Studies, Speaking, Assessment, Newsletter
 * 3. About — About Facundo, Contact
 * 4. Connect — Social links, newsletter signup
 * 
 * Features:
 * - semantic footer structure
 * - responsive grid layout
 * - brand information
 * - copyright notice
 * - dark premium background
 */

import { SITE } from '@/data/site';
import { FOOTER_NAV } from '@/data/navigation';

interface Props {
  currentYear?: number;
}

const { currentYear = new Date().getFullYear() } = Astro.props;
---

<footer class="footer">
  <div class="footer-container">
    {/* Footer Grid — 4 Columns */}
    <div class="footer-grid">
      {/* Column 1: Advisory */}
      <div class="footer-column">
        <h3 class="footer-column-title">Advisory</h3>
        <ul class="footer-links">
          {FOOTER_NAV.advisory.map(link => (
            <li>
              <a href={link.href} class="footer-link">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      {/* Column 2: Resources */}
      <div class="footer-column">
        <h3 class="footer-column-title">Resources</h3>
        <ul class="footer-links">
          {FOOTER_NAV.resources.map(link => (
            <li>
              <a href={link.href} class="footer-link">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      {/* Column 3: About */}
      <div class="footer-column">
        <h3 class="footer-column-title">About</h3>
        <ul class="footer-links">
          {FOOTER_NAV.about.map(link => (
            <li>
              <a href={link.href} class="footer-link">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      {/* Column 4: Connect */}
      <div class="footer-column">
        <h3 class="footer-column-title">Connect</h3>
        <div class="footer-connect">
          <p class="footer-description">
            Let's explore how AI and strategic thinking can transform your organization.
          </p>
          <div class="footer-social">
            <a 
              href={SITE.linkedin}
              target="_blank"
              rel="noopener noreferrer"
              class="footer-social-link"
              aria-label="LinkedIn"
            >
              <svg class="footer-social-icon" viewBox="0 0 24 24" fill="currentColor">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.475-2.236-1.986-2.236-1.081 0-1.722.731-2.004 1.438-.103.25-.129.599-.129.948v5.419h-3.554v-10.966h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 2.578 0 4.497 1.686 4.497 5.313v5.942zM5.337 9.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 10.019H3.555v-10.966h3.564v10.966zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.225 0z"/>
              </svg>
            </a>
            <a 
              href={`https://twitter.com/${SITE.twitterHandle.slice(1)}`}
              target="_blank"
              rel="noopener noreferrer"
              class="footer-social-link"
              aria-label="Twitter/X"
            >
              <svg class="footer-social-icon" viewBox="0 0 24 24" fill="currentColor">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24h-6.6l-5.165-6.75-5.91 6.75H2.42l7.728-8.835L1.424 2.25h6.76l4.676 6.188 5.604-6.188zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>

    {/* Footer Bottom — Copyright, Legal Links */}
    <div class="footer-bottom">
      <div class="footer-copyright">
        <p>
          © {currentYear} <span class="font-heading font-semibold">{SITE.name}</span>. 
          <span class="footer-tagline">AI Strategy & Enterprise Transformation Advisor</span>
        </p>
      </div>
      <div class="footer-legal">
        <a href="/privacy" class="footer-legal-link">Privacy</a>
        <span class="footer-legal-sep">·</span>
        <a href="/terms" class="footer-legal-link">Terms</a>
      </div>
    </div>
  </div>
</footer>

<style>
  /* Footer Root */
  :global(footer.footer) {
    @apply bg-navy-900 text-white;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
  }

  /* Container */
  :global(.footer-container) {
    @apply mx-auto max-w-6xl px-6 md:px-12 py-16 md:py-24;
  }

  /* Grid Layout — 4 Columns, responsive */
  :global(.footer-grid) {
    @apply grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 mb-12;
  }

  /* Column */
  :global(.footer-column) {
    display: flex;
    flex-direction: column;
  }

  /* Column Title */
  :global(.footer-column-title) {
    @apply font-heading font-bold text-lg text-white mb-4;
  }

  /* Links List */
  :global(.footer-links) {
    @apply list-none m-0 p-0 space-y-2;
  }

  /* Footer Link */
  :global(.footer-link) {
    @apply text-gray-400 text-sm transition-colors duration-200;
    @apply hover:text-orange-400;
    text-decoration: none;
  }

  :global(.footer-link:focus) {
    @apply outline-none ring-2 ring-orange-400 rounded px-1;
  }

  /* Connect Column Content */
  :global(.footer-connect) {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  /* Description Text */
  :global(.footer-description) {
    @apply text-gray-400 text-sm leading-relaxed;
    margin: 0;
  }

  /* Social Links */
  :global(.footer-social) {
    @apply flex items-center gap-3 pt-2;
  }

  /* Social Link Icon */
  :global(.footer-social-link) {
    @apply w-6 h-6 text-gray-400 transition-colors duration-200;
    @apply hover:text-orange-400 focus:outline-none focus:ring-2 focus:ring-orange-400 rounded p-0.5;
  }

  :global(.footer-social-icon) {
    @apply w-full h-full;
  }

  /* Footer Bottom Section */
  :global(.footer-bottom) {
    @apply flex flex-col md:flex-row md:items-center md:justify-between;
    @apply pt-8 border-t border-white border-opacity-10;
    gap: 1rem;
  }

  /* Copyright */
  :global(.footer-copyright) {
    @apply text-sm text-gray-400;
  }

  :global(.footer-copyright p) {
    margin: 0;
  }

  :global(.footer-tagline) {
    @apply block md:inline text-gray-500 text-xs mt-1 md:mt-0 md:ml-1;
  }

  /* Legal Links */
  :global(.footer-legal) {
    @apply flex items-center gap-3 text-xs;
  }

  /* Legal Link */
  :global(.footer-legal-link) {
    @apply text-gray-400 transition-colors duration-200;
    @apply hover:text-orange-400;
    text-decoration: none;
  }

  :global(.footer-legal-link:focus) {
    @apply outline-none ring-2 ring-orange-400 rounded px-1;
  }

  /* Separator */
  :global(.footer-legal-sep) {
    @apply opacity-50;
  }

  /* Responsive adjustments */
  @media (max-width: 768px) {
    :global(.footer-grid) {
      @apply gap-8;
    }

    :global(.footer-container) {
      @apply py-12;
    }
  }
</style>
