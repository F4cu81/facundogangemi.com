---
/**
 * Navbar — stable corrective version
 *
 * Purpose:
 * - Restore a clean global desktop/mobile navigation.
 * - Avoid Tailwind @apply and scoped utility dependencies.
 * - Keep static Astro compatibility.
 */

import { NAV_ITEMS, NAV_CTA } from '@/data/navigation';

interface Props {
  currentPath?: string;
  locale?: 'en' | 'es';
}

const { currentPath = '/', locale = 'en' } = Astro.props;
const isAdvisoryOpen = currentPath?.startsWith('/advisory');
---

<nav class="navbar-root" aria-label="Primary navigation">
  <div class="navbar-container container-site">
    <a href="/" class="navbar-logo" aria-label="Facundo Gangemi home">
      <img src="/favicon/favicon.svg" alt="" aria-hidden="true" width="24" height="24" class="navbar-logo-icon" />
      Facundo Gangemi
    </a>

    <div class="navbar-desktop">
      <ul class="navbar-menu">
        {NAV_ITEMS.map((item) => (
          <li class={`navbar-item ${item.hasDropdown ? 'has-dropdown' : ''}`}>
            <a
              href={item.href}
              class={`navbar-link ${currentPath === item.href ? 'active' : ''}`}
              aria-current={currentPath === item.href ? 'page' : undefined}
              aria-expanded={item.hasDropdown ? isAdvisoryOpen : undefined}
            >
              {item.label}
              {item.hasDropdown && <span class="navbar-arrow" aria-hidden="true">▾</span>}
            </a>

            {item.hasDropdown && item.children && (
              <ul class="navbar-dropdown" aria-label={`${item.label} submenu`}>
                {item.children.map((child) => (
                  <li>
                    <a
                      href={child.href}
                      class={`navbar-dropdown-link ${currentPath === child.href ? 'active' : ''}`}
                      aria-current={currentPath === child.href ? 'page' : undefined}
                    >
                      {child.label}
                    </a>
                  </li>
                ))}
              </ul>
            )}
          </li>
        ))}
      </ul>

      <div class="navbar-actions">
        <div class="language-switcher" aria-label="Language selector">
          <span class={`lang-option ${locale === 'en' ? 'active' : ''}`}>EN</span>
          <span class="lang-separator">/</span>
          <span class={`lang-option ${locale === 'es' ? 'active' : ''}`}>
            ES <span class="coming-soon">Soon</span>
          </span>
        </div>

        <a href={NAV_CTA.href} class="navbar-cta">
          {NAV_CTA.label}
        </a>
      </div>
    </div>

    <button
      id="mobile-menu-toggle"
      class="navbar-mobile-toggle"
      type="button"
      aria-label="Open mobile menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>
</nav>

<style>
  .navbar-root {
    position: sticky;
    top: 0;
    z-index: 100;
    width: 100%;
    background: rgba(7, 11, 20, 0.96);
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(14px);
  }

  .navbar-container {
    height: 72px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .navbar-logo {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: #ffffff;
    font-family: Manrope, Inter, system-ui, sans-serif;
    font-size: 1.125rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    text-decoration: none;
  }

  .navbar-logo:hover {
    color: #F57C00;
  }

  .navbar-logo-icon {
    display: block;
    width: 24px;
    height: 24px;
    flex-shrink: 0;
  }

  .navbar-desktop {
    display: none;
    align-items: center;
    gap: 2rem;
  }

  .navbar-menu {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .navbar-item {
    position: relative;
  }

  .navbar-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    color: rgba(255, 255, 255, 0.86);
    font-family: Inter, system-ui, sans-serif;
    font-size: 0.95rem;
    font-weight: 500;
    text-decoration: none;
    transition: color 180ms ease;
    white-space: nowrap;
  }

  .navbar-link:hover,
  .navbar-link.active {
    color: #F57C00;
  }

  .navbar-arrow {
    font-size: 0.72rem;
    line-height: 1;
  }

  .navbar-dropdown {
    position: absolute;
    top: calc(100% + 0.85rem);
    left: 0;
    min-width: 240px;
    padding: 0.5rem;
    margin: 0;
    list-style: none;
    background: #001B35;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 0.85rem;
    box-shadow: 0 18px 60px rgba(0, 0, 0, 0.28);
    opacity: 0;
    visibility: hidden;
    transform: translateY(8px);
    pointer-events: none;
    transition: opacity 160ms ease, transform 160ms ease, visibility 160ms ease;
  }

  .navbar-item.has-dropdown:hover .navbar-dropdown,
  .navbar-item.has-dropdown:focus-within .navbar-dropdown {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
    pointer-events: auto;
  }

  .navbar-dropdown-link {
    display: block;
    padding: 0.7rem 0.85rem;
    color: rgba(255, 255, 255, 0.82);
    font-size: 0.9rem;
    text-decoration: none;
    border-radius: 0.55rem;
    transition: background 160ms ease, color 160ms ease;
  }

  .navbar-dropdown-link:hover,
  .navbar-dropdown-link.active {
    color: #F57C00;
    background: rgba(255, 255, 255, 0.06);
  }

  .navbar-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .language-switcher {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    color: rgba(255, 255, 255, 0.62);
    font-size: 0.75rem;
    white-space: nowrap;
  }

  .lang-option.active {
    color: #ffffff;
    font-weight: 700;
  }

  .lang-separator {
    opacity: 0.5;
  }

  .coming-soon {
    font-size: 0.65rem;
    opacity: 0.6;
  }

  .navbar-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 42px;
    padding: 0 1.15rem;
    color: #ffffff;
    background: #F57C00;
    border-radius: 999px;
    font-family: Manrope, Inter, system-ui, sans-serif;
    font-size: 0.88rem;
    font-weight: 800;
    text-decoration: none;
    box-shadow: 0 8px 24px rgba(245, 124, 0, 0.28);
    transition: transform 180ms ease, background 180ms ease;
  }

  .navbar-cta:hover {
    background: #EF6C00;
    transform: translateY(-1px);
  }

  .navbar-mobile-toggle {
    display: inline-flex;
    width: 42px;
    height: 42px;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: 5px;
    padding: 0;
    background: transparent;
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 999px;
    cursor: pointer;
  }

  .navbar-mobile-toggle span {
    display: block;
    width: 18px;
    height: 2px;
    background: #ffffff;
    border-radius: 999px;
  }

  @media (min-width: 768px) {
    .navbar-desktop {
      display: flex;
    }

    .navbar-mobile-toggle {
      display: none;
    }
  }
</style>

<script>
  const mobileMenuToggle = document.getElementById('mobile-menu-toggle');

  mobileMenuToggle?.addEventListener('click', () => {
    const isExpanded = mobileMenuToggle.getAttribute('aria-expanded') === 'true';
    mobileMenuToggle.setAttribute('aria-expanded', String(!isExpanded));
    window.dispatchEvent(new CustomEvent('toggle-mobile-menu', { detail: { open: !isExpanded } }));
  });
</script>
